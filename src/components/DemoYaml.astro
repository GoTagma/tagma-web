---
// src/components/DemoYaml.astro
// YAML samples mirror the canonical schema used by @tagma/sdk. Source of truth:
//   tagma-mono/packages/sdk/src/schema.ts
//   tagma-mono/packages/sdk/examples/*.yaml
//
// Built-in at the SDK level (no plugin required):
//   - driver:      opencode
//   - triggers:    manual, file
//   - completions: exit_code, output_check, file_exists
//   - middleware:  static_context
// External plugins that MUST be declared under `plugins:` when used:
//   - '@tagma/driver-claude-code'   (models: opus, sonnet, haiku, …)
//   - '@tagma/driver-codex'         (models: gpt-5.3-codex, …; accepts reasoning_effort)
import { Code } from 'astro:components';

const parallelReviewYaml = `# .tagma/review.yaml
# Four reviewers run in parallel, then one task fans them in to a single
# report. Cross-track dependencies use the qualified \`<trackId>.<taskId>\`
# form. opencode is an SDK built-in, so only claude-code + codex need to
# be registered under \`plugins\`.
pipeline:
  name: pr-review
  timeout: 15m
  plugins:
    - '@tagma/driver-claude-code'
    - '@tagma/driver-codex'

  tracks:
    - id: security
      name: Security
      color: '#3b82f6'
      driver: claude-code
      model: sonnet
      permissions: { read: true, write: false, execute: false }
      tasks:
        - id: review
          name: Audit auth + secret handling
          prompt: 'Review this PR for auth, injection and secret-handling issues.'
          timeout: 5m

    - id: performance
      name: Performance
      color: '#14b8a6'
      driver: codex
      model: gpt-5.3-codex
      reasoning_effort: medium
      permissions: { read: true, write: false, execute: false }
      tasks:
        - id: hotpaths
          name: Flag perf regressions
          prompt: 'Identify perf regressions in the PR diff.'

    - id: style
      name: Style
      color: '#ec4899'
      driver: opencode
      model: opencode/big-pickle
      permissions: { read: true, write: false, execute: false }
      tasks:
        - id: idioms
          name: Flag style + idiom issues
          prompt: 'Flag style and idiom issues in the PR diff.'

    - id: consolidate
      name: Consolidate
      color: '#f97316'
      driver: claude-code
      model: opus
      tasks:
        - id: summary
          name: Merge reviewer reports
          prompt: 'Merge the three reviews into one report. Preserve severity.'
          depends_on:
            - security.review
            - performance.hotpaths
            - style.idioms
          continue_from: security.review
`;

const bugTriageYaml = `# .tagma/triage.yaml
# Single-track triage: reproduce → diagnose → fix → verify. Bare
# \`depends_on\` names resolve against the current track. \`on_failure:
# skip_downstream\` is the default; shown here for clarity.
pipeline:
  name: bug-triage
  timeout: 10m
  plugins:
    - '@tagma/driver-claude-code'

  tracks:
    - id: triage
      name: Triage
      color: '#22c55e'
      permissions: { read: true, write: true, execute: true }
      on_failure: skip_downstream
      tasks:
        - id: repro
          name: Reproduce the failure
          command: 'bun test --bail 1'
          completion:
            type: exit_code
            expect: [0, 1]

        - id: diagnose
          name: Locate the root cause
          driver: claude-code
          model: sonnet
          prompt: 'Read the failing test output and explain the root cause.'
          depends_on: [repro]
          continue_from: repro

        - id: fix
          name: Patch the defect
          driver: opencode
          model: opencode/big-pickle
          prompt: 'Patch the bug identified in diagnose. Keep the diff tight.'
          permissions: { read: true, write: true, execute: false }
          depends_on: [diagnose]
          continue_from: diagnose

        - id: verify
          name: Regression check
          command: 'bun test'
          depends_on: [fix]
          completion:
            type: output_check
            check: 'grep -qE "^(ok|pass)" '
            timeout: 30s
`;

const migrationGateYaml = `# .tagma/migration.yaml
# A write-enabled track is gated by a built-in \`manual\` trigger, so the
# run pauses until a human approves. Hooks attach to pipeline lifecycle
# events (see tagma-mono/packages/sdk/src/hooks.ts for the full list).
pipeline:
  name: migration
  timeout: 30m
  plugins:
    - '@tagma/driver-claude-code'
    - '@tagma/driver-codex'
  hooks:
    pipeline_start: 'echo "[hook] migration run $(date -u +%FT%TZ)"'
    task_success:
      - 'echo "[hook] task_success"'
    pipeline_complete: './scripts/notify-release.sh'

  tracks:
    - id: plan
      name: Plan
      color: '#ec4899'
      driver: claude-code
      model: opus
      tasks:
        - id: outline
          name: Outline migration + rollback
          prompt: 'Outline the migration steps and rollback plan in bullets.'

    - id: gate
      name: Approval
      color: '#94a3b8'
      tasks:
        - id: approve
          name: Human approval gate
          depends_on: [plan.outline]
          command: 'echo "approved — proceeding"'
          trigger:
            type: manual
            message: 'Apply this migration to production?'
            timeout: 10m
            metadata:
              stage: pre-apply
              requester: release-bot

    - id: apply
      name: Apply
      color: '#f97316'
      driver: codex
      model: gpt-5.3-codex
      reasoning_effort: high
      permissions: { read: true, write: true, execute: true }
      tasks:
        - id: run
          name: Apply the migration
          prompt: 'Apply the migration from plan.outline. Stop on any non-zero exit.'
          depends_on: [gate.approve]
          continue_from: plan.outline

        - id: verify
          name: Rollback smoke test
          command: './scripts/migrate-verify.sh'
          depends_on: [run]
          completion:
            type: exit_code
            expect: 0
`;

const smokeTestYaml = `# .tagma/test-pipeline.yaml
# End-to-end smoke test covering the full plugin surface. opencode,
# static_context, file trigger, and exit_code/output_check completions
# are all SDK built-ins — the only plugin declared here is claude-code
# for the final summarizer.
pipeline:
  name: full-feature-smoke-test
  driver: opencode
  model: opencode/big-pickle
  timeout: 30m
  plugins:
    - '@tagma/driver-claude-code'
  hooks:
    pipeline_start: 'echo "[hook] pipeline_start"'
    task_success:
      - 'echo "[hook] task_success #1"'
      - 'echo "[hook] task_success #2"'
    pipeline_complete: 'echo "[hook] pipeline_complete"'

  tracks:
    - id: backend
      name: Backend
      color: '#3b82f6'
      agent_profile: senior
      permissions: { read: true, write: true, execute: false }
      on_failure: skip_downstream
      middlewares:
        - type: static_context
          file: ./README.md
          label: Project Readme
      tasks:
        - id: plan
          name: Plan the /health change
          prompt: 'Plan the /health endpoint change in three bullets.'

        - id: implement
          name: Implement /health
          prompt: 'Based on the plan, modify the code to implement /health.'
          depends_on: [plan]
          continue_from: plan
          permissions: { read: true, write: true, execute: true }

        - id: review
          name: Self-review the diff
          prompt: 'Self-review the diff. Output a single line starting with PASS or FAIL.'
          depends_on: [implement]
          continue_from: implement
          middlewares: []
          completion:
            type: output_check
            check: 'grep -q "^PASS"'
            timeout: 30s

    - id: ops
      name: Ops
      color: '#22c55e'
      permissions: { read: true, write: true, execute: true }
      on_failure: ignore
      tasks:
        - id: prep
          name: Prepare signal dir
          command: 'mkdir -p ./.tagma/signal && echo ready > ./.tagma/signal/.ready'

        - id: wait-signal
          name: Wait for signal file
          command: 'echo "signal received"'
          depends_on: [prep]
          trigger:
            type: file
            path: ./.tagma/signal/.ready
            timeout: 1m
          completion:
            type: exit_code
            expect: [0]

    - id: review
      name: Review
      color: '#ec4899'
      driver: claude-code
      model: opus
      tasks:
        - id: summarize
          name: Summarize for release notes
          prompt: 'Summarize the backend run for the release notes.'
          depends_on:
            - backend.review
            - ops.wait-signal
          continue_from: backend.review
          completion:
            type: exit_code
            expect: 0
`;

const samples = [
  { id: 'parallel-review', file: '.tagma/review.yaml',        code: parallelReviewYaml },
  { id: 'bug-triage',      file: '.tagma/triage.yaml',        code: bugTriageYaml },
  { id: 'migration-gate',  file: '.tagma/migration.yaml',     code: migrationGateYaml },
  { id: 'smoke-test',      file: '.tagma/test-pipeline.yaml', code: smokeTestYaml },
];
---

<div class="demo-yaml" id="demoYaml" hidden>
  {samples.map((s) => (
    <div class="demo-yaml-block" data-yaml-id={s.id} hidden>
      <div class="demo-yaml-header">
        <span class="demo-yaml-file">{s.file}</span>
        <button class="demo-yaml-copy" type="button" data-copy={s.code}>COPY</button>
      </div>
      <div class="demo-yaml-body">
        <Code code={s.code} lang="yaml" theme="github-dark" />
      </div>
    </div>
  ))}
</div>
