---
// Docs search. The Pagefind UI is mounted inside a top-centered modal
// triggered by a button in the left sidebar (or ⌘K / Ctrl+K / "/" globally).
// The sidebar no longer hosts the search input or results.
---

<button type="button" class="docs-search-trigger" data-docs-search-open aria-label="Search docs">
  <span class="docs-search-trigger__label">Search</span>
  <kbd class="docs-search-trigger__kbd">⌘K</kbd>
</button>

<div class="docs-search-modal" data-docs-search-modal hidden aria-modal="true" role="dialog" aria-label="Search docs">
  <div class="docs-search-modal__backdrop" data-docs-search-close></div>
  <div class="docs-search-modal__panel" role="document">
    <button
      type="button"
      class="docs-search-modal__close"
      data-docs-search-close
      aria-label="Close search"
    >×</button>
    <div id="docs-search-mount"></div>
  </div>
</div>

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
<script is:inline>
  (function () {
    var initialized = false;
    var modal = null;
    var trigger = null;

    function ensurePagefind() {
      if (initialized) return;
      initialized = true;
      var script = document.createElement('script');
      script.src = '/pagefind/pagefind-ui.js';
      script.onload = function () {
        new window.PagefindUI({
          element: '#docs-search-mount',
          showSubResults: true,
          showImages: false,
          resetStyles: false,
          translations: { placeholder: 'Search docs…' },
        });
        requestAnimationFrame(function () {
          var input = document.querySelector(
            '#docs-search-mount input[type="search"], #docs-search-mount input'
          );
          if (input) input.focus();
        });
      };
      document.head.appendChild(script);
    }

    function openModal() {
      if (!modal) return;
      modal.removeAttribute('hidden');
      document.documentElement.classList.add('docs-search-open');
      ensurePagefind();
      var input = modal.querySelector('input[type="search"], input');
      if (input) input.focus();
    }

    function closeModal() {
      if (!modal) return;
      modal.setAttribute('hidden', '');
      document.documentElement.classList.remove('docs-search-open');
      if (trigger) trigger.focus();
    }

    function isEditable(el) {
      if (!el) return false;
      var tag = el.tagName;
      return tag === 'INPUT' || tag === 'TEXTAREA' || el.isContentEditable;
    }

    function boot() {
      modal = document.querySelector('[data-docs-search-modal]');
      trigger = document.querySelector('[data-docs-search-open]');
      if (!modal || !trigger) return;

      trigger.addEventListener('click', openModal);

      document.querySelectorAll('[data-docs-search-close]').forEach(function (el) {
        el.addEventListener('click', closeModal);
      });

      document.addEventListener('keydown', function (e) {
        var open = !modal.hasAttribute('hidden');
        if (e.key === 'Escape' && open) {
          e.preventDefault();
          closeModal();
          return;
        }
        if (open) return;
        var meta = e.metaKey || e.ctrlKey;
        if (meta && (e.key === 'k' || e.key === 'K')) {
          e.preventDefault();
          openModal();
          return;
        }
        if (e.key === '/' && !isEditable(document.activeElement)) {
          e.preventDefault();
          openModal();
        }
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', boot);
    } else {
      boot();
    }
  })();
</script>

<style is:global>
  /* ─── Sidebar trigger ─── */
  .docs-search-trigger {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; margin-bottom: 18px; padding: 8px 10px;
    background: var(--bg-1); border: 1px solid var(--line);
    color: var(--fg-dim); font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 12px; letter-spacing: .02em;
    cursor: pointer; transition: color .12s ease, border-color .12s ease;
  }
  .docs-search-trigger:hover { color: var(--fg); border-color: var(--line-2); }
  .docs-search-trigger__label { opacity: .9; }
  .docs-search-trigger__kbd {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: .06em; color: var(--fg-muted);
    background: var(--bg-2); border: 1px solid var(--line);
    padding: 1px 6px;
  }

  /* ─── Modal ─── */
  .docs-search-modal[hidden] { display: none; }
  .docs-search-modal {
    position: fixed; inset: 0; z-index: 1000;
    display: flex; justify-content: center;
    padding: 12vh 20px 20px;
  }
  .docs-search-modal__backdrop {
    position: absolute; inset: 0;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(2px);
  }
  .docs-search-modal__panel {
    position: relative; z-index: 1;
    width: 100%; max-width: 640px;
    background: var(--bg); border: 1px solid var(--line);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.4);
    padding: 20px 20px 16px;
    max-height: calc(100vh - 14vh - 40px);
    overflow: auto;
  }
  .docs-search-modal__close {
    position: absolute; top: 8px; right: 10px;
    font-family: 'JetBrains Mono', monospace; font-size: 18px; line-height: 1;
    color: var(--fg-muted); background: transparent; border: 0;
    cursor: pointer; padding: 4px 8px;
  }
  .docs-search-modal__close:hover { color: var(--fg); }

  html.docs-search-open, html.docs-search-open body { overflow: hidden; }

  #docs-search-mount .pagefind-ui {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: var(--accent);
    --pagefind-ui-text: var(--fg);
    --pagefind-ui-background: var(--bg);
    --pagefind-ui-border: var(--line);
    --pagefind-ui-tag: var(--bg-2);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0;
    --pagefind-ui-font: 'Space Grotesk', system-ui, sans-serif;
  }
  #docs-search-mount .pagefind-ui__search-input {
    font-family: 'JetBrains Mono', monospace; font-size: 13px;
  }
</style>
