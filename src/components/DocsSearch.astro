---
// Pagefind UI mounted into the docs left sidebar. The CSS and JS bundles
// live under /pagefind/ — generated by the postbuild step in package.json.
---

<div class="docs-search">
  <div id="docs-search-mount"></div>
</div>

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
<script is:inline>
  (function () {
    function boot() {
      var script = document.createElement('script');
      script.src = '/pagefind/pagefind-ui.js';
      script.onload = function () {
        new window.PagefindUI({
          element: '#docs-search-mount',
          showSubResults: true,
          showImages: false,
          resetStyles: false,
          translations: { placeholder: 'Search docs…' },
        });
      };
      document.head.appendChild(script);
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', boot);
    } else {
      boot();
    }
  })();
</script>

<style is:global>
  .docs-search { margin-bottom: 18px; }
  .docs-search .pagefind-ui {
    --pagefind-ui-scale: 0.85;
    --pagefind-ui-primary: var(--accent);
    --pagefind-ui-text: var(--fg);
    --pagefind-ui-background: var(--bg-1);
    --pagefind-ui-border: var(--line);
    --pagefind-ui-tag: var(--bg-2);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0;
    --pagefind-ui-font: 'Space Grotesk', system-ui, sans-serif;
  }
  .docs-search .pagefind-ui__search-input {
    font-family: 'JetBrains Mono', monospace; font-size: 12px;
  }
</style>
