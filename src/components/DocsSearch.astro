---
// Docs search. The Pagefind UI is mounted inside a native <dialog>
// triggered by a button in the left sidebar (or ⌘K / Ctrl+K / "/").
// Using <dialog> + showModal() puts the panel in the browser's top
// layer, which renders above every stacking context — no z-index
// required, no interference from sticky headers or sidebars.
---

<button type="button" class="docs-search-trigger" data-docs-search-open aria-label="Search docs">
  <span class="docs-search-trigger__label">Search</span>
  <kbd class="docs-search-trigger__kbd">⌘K</kbd>
</button>

<dialog class="docs-search-modal" data-docs-search-modal aria-label="Search docs">
  <div class="docs-search-modal__panel">
    <div id="docs-search-mount"></div>
  </div>
</dialog>

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
<script is:inline>
  (function () {
    var initialized = false;
    var dialog = null;
    var trigger = null;

    function ensurePagefind() {
      if (initialized) return;
      initialized = true;
      var script = document.createElement('script');
      script.src = '/pagefind/pagefind-ui.js';
      script.onload = function () {
        new window.PagefindUI({
          element: '#docs-search-mount',
          showSubResults: true,
          showImages: false,
          resetStyles: false,
          translations: { placeholder: 'Search docs…' },
        });
        requestAnimationFrame(focusInput);
      };
      document.head.appendChild(script);
    }

    function focusInput() {
      if (!dialog) return;
      var input = dialog.querySelector('input[type="search"], input');
      if (input) input.focus();
    }

    function openModal() {
      if (!dialog) return;
      if (typeof dialog.showModal === 'function') {
        if (!dialog.open) dialog.showModal();
      } else {
        dialog.setAttribute('open', '');
      }
      document.documentElement.classList.add('docs-search-open');
      ensurePagefind();
      focusInput();
    }

    function closeModal() {
      if (!dialog) return;
      if (typeof dialog.close === 'function' && dialog.open) dialog.close();
      else dialog.removeAttribute('open');
      document.documentElement.classList.remove('docs-search-open');
      if (trigger) trigger.focus();
    }

    function isEditable(el) {
      if (!el) return false;
      var tag = el.tagName;
      return tag === 'INPUT' || tag === 'TEXTAREA' || el.isContentEditable;
    }

    function boot() {
      dialog = document.querySelector('[data-docs-search-modal]');
      trigger = document.querySelector('[data-docs-search-open]');
      if (!dialog || !trigger) return;

      trigger.addEventListener('click', openModal);

      // Click on the ::backdrop surfaces as a click on the dialog itself.
      dialog.addEventListener('click', function (e) {
        if (e.target === dialog) closeModal();
      });

      // <dialog> handles Esc natively via the 'cancel' event; sync our state.
      dialog.addEventListener('close', function () {
        document.documentElement.classList.remove('docs-search-open');
      });

      document.addEventListener('keydown', function (e) {
        if (dialog.open) return;
        var meta = e.metaKey || e.ctrlKey;
        if (meta && (e.key === 'k' || e.key === 'K')) {
          e.preventDefault();
          openModal();
          return;
        }
        if (e.key === '/' && !isEditable(document.activeElement)) {
          e.preventDefault();
          openModal();
        }
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', boot);
    } else {
      boot();
    }
  })();
</script>

<style is:global>
  /* ─── Sidebar trigger ─── */
  .docs-search-trigger {
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; margin-bottom: 18px; padding: 8px 10px;
    background: var(--bg-1); border: 1px solid var(--line);
    color: var(--fg-dim); font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 12px; letter-spacing: .02em;
    cursor: pointer; transition: color .12s ease, border-color .12s ease;
  }
  .docs-search-trigger:hover { color: var(--fg); border-color: var(--line-2); }
  .docs-search-trigger__label { opacity: .9; }
  .docs-search-trigger__kbd {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: .06em; color: var(--fg-muted);
    background: var(--bg-2); border: 1px solid var(--line);
    padding: 1px 6px;
  }

  /* ─── Native <dialog> styling ─── */
  /* The element is in the top layer when opened via showModal(); no
     z-index needed. We style the default appearance and use flexbox
     to pin the panel near the top of the viewport. */
  .docs-search-modal {
    /* Override UA centering — we want top-ish positioning. */
    padding: 0; border: 0; background: transparent; color: inherit;
    margin: 12vh auto auto; /* top 12vh, horizontally centered */
    max-width: 640px; width: calc(100% - 40px);
    max-height: calc(100vh - 14vh - 40px);
    overflow: visible;
  }
  .docs-search-modal::backdrop {
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(2px);
  }
  /* Panel is a flex column: form is pinned at the top (non-scrolling),
     drawer is the only scroll surface. This keeps the search input
     visible while the result list scrolls underneath. */
  .docs-search-modal__panel {
    position: relative;
    display: flex; flex-direction: column;
    background: var(--bg); border: 1px solid var(--line);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.4);
    max-height: calc(100vh - 14vh - 40px);
    overflow: hidden;
  }

  html.docs-search-open, html.docs-search-open body { overflow: hidden; }

  /* Propagate the column-flex layout through the Pagefind wrapper
     down to its form/drawer so the drawer can actually scroll. */
  #docs-search-mount {
    display: flex; flex-direction: column;
    flex: 1 1 auto; min-height: 0;
  }
  #docs-search-mount .pagefind-ui {
    display: flex; flex-direction: column;
    flex: 1 1 auto; min-height: 0;
  }
  #docs-search-mount .pagefind-ui__form {
    flex: 0 0 auto;
    padding: 18px 20px 14px;
    background: var(--bg);
    border-bottom: 1px solid var(--line);
    margin: 0;
  }
  #docs-search-mount .pagefind-ui__drawer {
    flex: 1 1 auto;
    overflow-y: auto; overflow-x: hidden;
    padding: 14px 20px 20px;
    min-height: 0;
  }

  /* Theming + polish. */
  #docs-search-mount .pagefind-ui {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: var(--accent);
    --pagefind-ui-text: var(--fg);
    --pagefind-ui-background: var(--bg);
    --pagefind-ui-border: var(--line);
    --pagefind-ui-tag: var(--bg-2);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0;
    --pagefind-ui-font: 'Space Grotesk', system-ui, sans-serif;
  }
  #docs-search-mount .pagefind-ui__search-input {
    font-family: 'JetBrains Mono', monospace; font-size: 14px;
    padding: 10px 40px 10px 40px;
    line-height: 1.4;
  }
  /* Center the magnifying-glass and clear-button icons vertically
     inside the input and give them a consistent click target. */
  #docs-search-mount .pagefind-ui__form::before,
  #docs-search-mount .pagefind-ui__search-clear {
    top: 50% !important; transform: translateY(-50%);
    display: inline-flex; align-items: center; justify-content: center;
  }
  #docs-search-mount .pagefind-ui__search-clear {
    right: 12px;
    height: 24px; min-width: 24px; padding: 0 8px;
    font-size: 11px; letter-spacing: .04em;
    color: var(--fg-muted); background: transparent;
  }
  #docs-search-mount .pagefind-ui__search-clear:hover { color: var(--fg); }
  /* Result rows: consistent padding, subtle separators, no images. */
  #docs-search-mount .pagefind-ui__result {
    padding: 12px 0; border-bottom: 1px solid var(--line);
  }
  #docs-search-mount .pagefind-ui__result:last-child { border-bottom: 0; }
  #docs-search-mount .pagefind-ui__result-title {
    font-size: 14px; font-weight: 500; color: var(--fg);
  }
  #docs-search-mount .pagefind-ui__result-excerpt {
    font-size: 12px; color: var(--fg-dim); line-height: 1.5; margin-top: 4px;
  }
  #docs-search-mount .pagefind-ui__message {
    font-size: 12px; color: var(--fg-muted);
    font-family: 'JetBrains Mono', monospace; letter-spacing: .04em;
  }
</style>
