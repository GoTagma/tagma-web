---
import { site } from '../site.config';

interface Props { currentPath: string }
const { currentPath } = Astro.props;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/' || currentPath === '';
  return currentPath === href || currentPath.startsWith(href + '/');
}

const flatNav = [
  { href: '/pricing',  key: 'pricing',  i18n: 'nav.pricing',  label: 'Pricing' },
  { href: '/showcase', key: 'showcase', i18n: 'nav.showcase', label: 'Showcase' },
];

const products = [
  { key: 'editor', num: '01',
    kindI18n: 'nav.mega.kind.desktop', kindLabel: 'DESKTOP',
    nameI18n: 'nav.mega.editor.name',  name: 'Tagma Editor',
    descI18n: 'nav.mega.editor.desc',
    desc: 'Swim-lane UI — design, run, replay.',
    tag: `v${site.version}`,
    href: '/#download', external: false,
  },
  { key: 'sdk', num: '02',
    kindI18n: 'nav.mega.kind.library', kindLabel: 'LIBRARY',
    nameI18n: 'nav.mega.sdk.name',     name: '@tagma/sdk',
    descI18n: 'nav.mega.sdk.desc',
    desc: 'TypeScript SDK. Same runtime, imported as a library.',
    tag: 'npm',
    href: site.github.sdk, external: true,
  },
  { key: 'cli', num: '03',
    kindI18n: 'nav.mega.kind.shell',   kindLabel: 'SHELL',
    nameI18n: 'nav.mega.cli.name',     name: '@tagma/cli',
    descI18n: 'nav.mega.cli.desc',
    desc: 'Run any pipeline.yaml from a terminal.',
    tag: 'npm',
    href: site.github.cli, external: true,
  },
];

const resources = [
  { key: 'docs',      href: '/docs',      external: false,
    nameI18n: 'nav.res.docs',      name: 'Docs',
    subI18n:  'nav.res.docs.sub',  sub:  'Install, pipelines, drivers' },
  { key: 'changelog', href: '/archive',   external: false,
    nameI18n: 'nav.res.changelog', name: 'Changelog',
    subI18n:  'nav.res.changelog.sub', sub: `v${site.version} · latest`, fresh: true },
  { key: 'api',       href: '/docs#sdk',  external: false,
    nameI18n: 'nav.res.api',       name: 'API Reference',
    subI18n:  'nav.res.api.sub',   sub:  'SDK & CLI types' },
  { key: 'examples',  href: '/docs#first-pipeline', external: false,
    nameI18n: 'nav.res.examples',  name: 'Examples',
    subI18n:  'nav.res.examples.sub', sub: 'Open-source pipelines' },
  { key: 'github',    href: site.github.mono, external: true,
    nameI18n: 'nav.res.github',    name: 'GitHub',
    subI18n:  'nav.res.github.sub', sub: 'Source · issues · releases' },
  { key: 'community', href: '#',          external: false,
    nameI18n: 'nav.res.community', name: 'Community',
    subI18n:  'nav.res.community.sub', sub: 'Discord · X · discussions' },
];

const communityLinks = [
  { key: 'discord', href: site.community.discord, external: true,
    name: 'Discord', sub: 'Real-time chat · plugin help',
    icon: 'M13.5 3.3A12 12 0 0 0 10.4 2.4l-.15.3a10.5 10.5 0 0 1 3 1.3C11.4 3.2 9.4 3 8 3s-3.4.2-5.3 1A10.5 10.5 0 0 1 5.8 2.7l-.2-.3A12 12 0 0 0 2.5 3.3 13 13 0 0 0 .1 12a11.5 11.5 0 0 0 3.5 1.8l.7-1.1a7.5 7.5 0 0 1-1.2-.6l.3-.2a8.6 8.6 0 0 0 9.2 0l.3.2c-.4.2-.8.4-1.2.6l.7 1.1A11.5 11.5 0 0 0 15.9 12a13 13 0 0 0-2.4-8.7ZM5.8 10c-.7 0-1.3-.7-1.3-1.5S5 7 5.8 7c.7 0 1.3.7 1.3 1.5S6.5 10 5.8 10Zm4.4 0c-.7 0-1.3-.7-1.3-1.5S9.5 7 10.2 7c.8 0 1.3.7 1.3 1.5S11 10 10.2 10Z' },
  { key: 'x',       href: site.community.x,       external: true,
    name: 'X (Twitter)', sub: 'Release notes · dev logs',
    icon: 'M9.3 6.8 14.7 .6h-1.3L8.7 6 4.9.6H.5L6.2 8.8.5 15.4h1.3l5-5.8 4 5.8h4.4L9.3 6.8Zm-1.8 2L7 8.2 2.3 1.5H4l3.7 5.4.5.8 4.7 6.8H11.2L7.5 8.9Z' },
  { key: 'youtube', href: site.community.youtube, external: true,
    name: 'YouTube', sub: 'Demos · tutorials · walkthroughs',
    icon: 'M15.5 4.5a2 2 0 0 0-1.4-1.4C12.9 2.8 8 2.8 8 2.8s-4.9 0-6.1.3A2 2 0 0 0 .5 4.5 21 21 0 0 0 .2 8a21 21 0 0 0 .3 3.5 2 2 0 0 0 1.4 1.4c1.2.3 6.1.3 6.1.3s4.9 0 6.1-.3a2 2 0 0 0 1.4-1.4A21 21 0 0 0 15.8 8a21 21 0 0 0-.3-3.5ZM6.4 10.3V5.7L10.4 8l-4 2.3Z' },
];
---

<div class="topbar-inner v2-topbar">
  <div class="v2-left">
    <a class="brand" href="/">
      <span class="mark" aria-hidden="true"></span>
      <span>{site.name}</span>
      <span class="v">v{site.version}</span>
    </a>

    <nav class="v2-nav" aria-label="Primary">
      <div class="v2-nav-item" data-menu="product">
        <button type="button" class="v2-nav-trigger" aria-haspopup="true" aria-expanded="false">
          <span data-i18n="nav.product">Product</span>
          <span class="chev" aria-hidden="true">▾</span>
        </button>
      </div>

      <div class="v2-nav-item" data-menu="resources">
        <button type="button" class="v2-nav-trigger" aria-haspopup="true" aria-expanded="false">
          <span data-i18n="nav.resources">Resources</span>
          <span class="chev" aria-hidden="true">▾</span>
        </button>
      </div>

      <div class="v2-nav-item" data-menu="community">
        <button type="button" class="v2-nav-trigger" aria-haspopup="true" aria-expanded="false">
          <span data-i18n="nav.community">Community</span>
          <span class="chev" aria-hidden="true">▾</span>
        </button>
      </div>

      {flatNav.map((item) => (
        <a
          href={item.href}
          class={`v2-nav-link${isActive(item.href) ? ' active' : ''}`}
          data-nav={item.key}
          data-i18n={item.i18n}
        >{item.label}</a>
      ))}
    </nav>
  </div>

  <div class="v2-mid" aria-hidden="true"></div>

  <div class="topbar-right v2-right">
    <div class="lang-menu" id="lang">
      <button class="trigger" type="button" aria-haspopup="listbox" aria-expanded="false">
        <span class="label">EN</span><span class="caret">▾</span>
      </button>
      <div class="panel" role="listbox">
        <button class="opt active" data-v="en" type="button">English<span class="code">EN</span></button>
        <button class="opt"        data-v="zh" type="button">中文<span class="code">ZH</span></button>
        <button class="opt disabled" type="button">日本語<span class="code">Soon</span></button>
        <button class="opt disabled" type="button">Español<span class="code">Soon</span></button>
      </div>
    </div>

    <button class="theme-btn" id="themeBtn" title="Toggle theme" aria-label="Toggle theme">◐</button>

    <a class="v2-signin" href="/login" data-i18n="nav.signin">Sign in</a>

    <div class="dl-wrap">
      <a class="accent-btn dl-btn" href="/#download" data-i18n="cta.download" aria-describedby="dlTip">↓ Download</a>
      <div class="dl-tip" id="dlTip" role="tooltip">
        <div class="dl-tip-head">
          <span class="sq" aria-hidden="true"></span>
          <span class="kicker" data-i18n="dl.tip.kicker">LATEST RELEASE</span>
        </div>
        <dl class="dl-tip-rows">
          <div><dt data-i18n="dl.tip.ver">Version</dt><dd>v{site.version} · <span class="muted">{site.channel.toUpperCase()}</span></dd></div>
          <div><dt data-i18n="dl.tip.date">Build</dt><dd>{site.buildDate} · <span class="muted">#{site.build}</span></dd></div>
          <div><dt data-i18n="dl.tip.size">Size</dt><dd>{site.sizeMB} MB · <span class="muted">{site.platforms.join(' · ')}</span></dd></div>
          <div><dt data-i18n="dl.tip.sha">SHA-256</dt><dd class="mono-tight">{site.sha256Short}</dd></div>
        </dl>
        <div class="dl-tip-foot" data-i18n="dl.tip.foot">Click to download · signed build</div>
      </div>
    </div>
  </div>
</div>

{/* ─── Mega: Product ─── */}
<div class="v2-mega" data-mega="product" hidden>
  <div class="v2-mega-inner">
    <div class="v2-mega-grid">
      {products.map((p) => (
        <a class="v2-mega-cell" href={p.href} {...(p.external ? { target: '_blank', rel: 'noopener' } : {})}>
          <div class="kind"><span class="n">{p.num}</span> · <span data-i18n={p.kindI18n}>{p.kindLabel}</span></div>
          <div class="n2">
            <span class="name" data-i18n={p.nameI18n}>{p.name}</span>
            <span class="tag">{p.tag}</span>
          </div>
          <div class="desc" data-i18n={p.descI18n}>{p.desc}</div>
          <div class="arrow" data-i18n="nav.mega.learn">Learn more →</div>
        </a>
      ))}
    </div>
    <div class="v2-mega-foot">
      <a href="/#download"><span data-i18n="nav.mega.foot.dl">↓ Download desktop</span> · {site.sizeMB} MB</a>
      <span class="dot">│</span>
      <a href="/docs" data-i18n="nav.mega.foot.api">API reference →</a>
    </div>

    <div class="v2-install-chips">
      <button type="button" class="v2-install-chip" data-install-copy={site.install.sdk}>
        <span class="cmd" data-i18n="nav.mega.install.sdk">$ {site.install.sdk}</span>
        <span class="copy-label" data-i18n="nav.mega.install.copy">Copy</span>
        <span class="copy-done" data-i18n="nav.mega.install.copied">✓ Copied</span>
      </button>
      <button type="button" class="v2-install-chip" data-install-copy={site.install.curl}>
        <span class="cmd" data-i18n="nav.mega.install.curl">$ {site.install.curl}</span>
        <span class="copy-label" data-i18n="nav.mega.install.copy">Copy</span>
        <span class="copy-done" data-i18n="nav.mega.install.copied">✓ Copied</span>
      </button>
    </div>
  </div>
</div>

{/* ─── Mega: Resources ─── */}
<div class="v2-mega" data-mega="resources" hidden>
  <div class="v2-mega-inner">
    <div class="v2-mega-list">
      {resources.map((r) => (
        <a class="v2-mega-row" href={r.href} {...(r.external ? { target: '_blank', rel: 'noopener' } : {})}>
          <div>
            <div class="rn">
              {r.fresh && <span class="fresh-dot" aria-hidden="true"></span>}
              <span data-i18n={r.nameI18n}>{r.name}</span>
            </div>
            <div class="rs" data-i18n={r.subI18n}>{r.sub}</div>
          </div>
          <span class="chev-r" aria-hidden="true">→</span>
        </a>
      ))}
    </div>
  </div>
</div>

{/* ─── Mega: Community ─── */}
<div class="v2-mega" data-mega="community" hidden>
  <div class="v2-mega-inner">
    <div class="v2-mega-list v2-mega-list--community">
      {communityLinks.map((c) => (
        <a class="v2-mega-row" href={c.href} target="_blank" rel="noopener">
          <div>
            <div class="rn">
              <span class="icn" aria-hidden="true">
                <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor"><path d={c.icon}/></svg>
              </span>
              <span>{c.name}</span>
            </div>
            <div class="rs">{c.sub}</div>
          </div>
          <span class="chev-r" aria-hidden="true">↗</span>
        </a>
      ))}
    </div>
  </div>
</div>

<script>
  (function megaMenu() {
    const items = document.querySelectorAll<HTMLElement>('.v2-nav-item[data-menu]');
    let openKey: string | null = null;

    const panelFor   = (k: string) => document.querySelector<HTMLElement>(`[data-mega="${k}"]`);
    const triggerFor = (k: string) => document.querySelector<HTMLElement>(`.v2-nav-item[data-menu="${k}"] .v2-nav-trigger`);

    function open(key: string) {
      if (openKey === key) return;
      if (openKey) closeNow();
      const p = panelFor(key), t = triggerFor(key);
      if (!p || !t) return;
      p.removeAttribute('hidden');
      t.setAttribute('aria-expanded', 'true');
      t.classList.add('open');
      openKey = key;
    }
    function closeNow() {
      if (!openKey) return;
      const p = panelFor(openKey), t = triggerFor(openKey);
      p?.setAttribute('hidden', '');
      t?.setAttribute('aria-expanded', 'false');
      t?.classList.remove('open');
      openKey = null;
    }

    items.forEach((item) => {
      const key = item.dataset.menu;
      if (!key) return;
      const trigger = item.querySelector<HTMLElement>('.v2-nav-trigger');
      trigger?.addEventListener('click', (e) => {
        e.preventDefault();
        openKey === key ? closeNow() : open(key);
      });
    });
    document.addEventListener('click', (e) => {
      const t = e.target as HTMLElement;
      if (!t.closest('.v2-nav-item') && !t.closest('.v2-mega')) closeNow();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeNow();
    });
  })();

  document.querySelectorAll<HTMLButtonElement>('.v2-install-chip').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const cmd = btn.dataset.installCopy || '';
      try {
        await navigator.clipboard.writeText(cmd);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = cmd;
        ta.setAttribute('readonly', '');
        ta.style.position = 'fixed'; ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand('copy'); } catch { }
        ta.remove();
      }
      btn.classList.add('is-copied');
      window.setTimeout(() => btn.classList.remove('is-copied'), 1400);
    });
  });
</script>
