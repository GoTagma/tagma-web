---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import DocsPrevNext from './DocsPrevNext.astro';
import { findPrevNext } from '../lib/docs-nav';
import DocsSearch from './DocsSearch.astro';

interface Props { entry: CollectionEntry<'docs'> }
const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const allDocs = await getCollection('docs');
// Group order follows the lowest-order doc per group (matches findPrevNext in docs-nav.ts).
const sortedDocs = [...allDocs].sort((a, b) => a.data.order - b.data.order);
const byGroup = new Map<string, CollectionEntry<'docs'>[]>();
for (const d of sortedDocs) {
  const g = d.data.group;
  if (!byGroup.has(g)) byGroup.set(g, []);
  byGroup.get(g)!.push(d);
}
const groupedDocs = Array.from(byGroup.entries());
const { prev, next } = findPrevNext(allDocs, entry.id);
---

<BaseLayout title={`${entry.data.title} — Tagma Docs`} description={entry.data.description}>
  <main>
    <div class="doc-layout">
      <aside class="doc-side">
        <DocsSearch />
        <button
          class="doc-collapse"
          type="button"
          data-collapse-toggle="side"
          aria-expanded="false"
          aria-controls="docSideNav"
        >
          <span>Browse docs</span>
          <span class="chev" aria-hidden="true">▾</span>
        </button>
        <div class="doc-side-nav" id="docSideNav">
          {groupedDocs.map(([group, docs]) => (
            <Fragment>
              <h5>{group}</h5>
              {docs.map((d) => (
                <a
                  href={`/docs/${d.id}`}
                  class={d.id === entry.id ? 'active' : undefined}
                >{d.data.title}</a>
              ))}
            </Fragment>
          ))}
        </div>
      </aside>

      <article class="doc-main">
        <div class="doc-search-results" data-docs-search-results hidden>
          <div class="docs-search-summary" data-docs-search-summary></div>
          <div class="docs-search-list" data-docs-search-list></div>
        </div>
        <div class="crumb">DOCS<span class="sep">/</span>{entry.data.group.toUpperCase()}<span class="sep">/</span>{entry.data.title.toUpperCase()}</div>
        <h1>{entry.data.title}</h1>
        {entry.data.description && <p class="lede">{entry.data.description}</p>}

        {headings.filter((h) => h.depth === 2 || h.depth === 3).length > 0 && (
          <div class="doc-toc-inline">
            <button
              class="doc-collapse"
              type="button"
              data-collapse-toggle="toc"
              aria-expanded="false"
              aria-controls="docTocInline"
            >
              <span>On this page</span>
              <span class="chev" aria-hidden="true">▾</span>
            </button>
            <div class="doc-toc-inline-list" id="docTocInline">
              {headings.filter((h) => h.depth === 2 || h.depth === 3).map((h) => (
                <a href={`#${h.slug}`} class={h.depth === 3 ? 'sub' : undefined}>{h.text.replace(/\s*#\s*$/, '').trim()}</a>
              ))}
            </div>
          </div>
        )}

        <Content />
        {entry.data.updated && (
          <p class="doc-updated">Last updated: {entry.data.updated}</p>
        )}
        <DocsPrevNext prev={prev} next={next} />
      </article>

      <aside class="doc-toc">
        <h5>On this page</h5>
        {headings.filter((h) => h.depth === 2 || h.depth === 3).map((h) => (
          <a href={`#${h.slug}`} class={h.depth === 3 ? 'sub' : undefined}>{h.text.replace(/\s*#\s*$/, '').trim()}</a>
        ))}
      </aside>
    </div>
  </main>
</BaseLayout>

<style is:global>
  .doc-layout {
    max-width: 1360px; margin: 0 auto;
    display: grid; grid-template-columns: 240px minmax(0, 1fr) 220px;
    gap: 0; min-height: calc(100vh - 56px);
  }
  .doc-side {
    border-right: 1px solid var(--line);
    padding: 32px 24px; background: var(--bg);
    position: sticky; top: 56px; align-self: start;
    max-height: calc(100vh - 56px); overflow: auto;
  }
  .doc-side h5 { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: .12em; text-transform: uppercase; color: var(--fg-muted); margin: 18px 0 10px; font-weight: 500; }
  .doc-side h5:first-child { margin-top: 0; }
  .doc-side a { display: block; padding: 6px 0; font-size: 13px; color: var(--fg-dim); border-left: 2px solid transparent; padding-left: 12px; margin-left: -12px; }
  .doc-side a:hover { color: var(--fg); }
  .doc-side a.active { color: var(--accent); border-left-color: var(--accent); }

  .doc-main { padding: 56px 56px 200px; max-width: 820px; }
  .doc-main .crumb { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--fg-muted); letter-spacing: .08em; text-transform: uppercase; margin-bottom: 20px; }
  .doc-main .crumb .sep { color: var(--line-2); margin: 0 8px; }
  .doc-main h1 { font-size: clamp(36px, 5vw, 56px); line-height: 1.04; letter-spacing: -.03em; font-weight: 500; margin-bottom: 14px; }
  .doc-main .lede { font-size: 18px; color: var(--fg-dim); line-height: 1.55; margin-bottom: 40px; max-width: 62ch; }
  .doc-main h2 { font-size: 26px; font-weight: 500; letter-spacing: -.01em; margin: 48px 0 12px; }
  .doc-main h3 { font-size: 16px; font-weight: 600; margin: 28px 0 10px; color: var(--fg); }
  .doc-main p { font-size: 15px; color: var(--fg-dim); line-height: 1.7; margin-bottom: 12px; max-width: 62ch; }
  .doc-main strong, .doc-main b { color: var(--fg); font-weight: 600; }
  .doc-main code { font-family: 'JetBrains Mono', monospace; font-size: 13px; background: var(--bg-1); padding: 2px 6px; border: 1px solid var(--line); color: var(--fg); }
  .doc-main .code-block { position: relative; margin: 16px 0 24px; }
  .doc-main .code-block pre.astro-code,
  .doc-main pre { font-family: 'JetBrains Mono', monospace; font-size: 13px; border: 1px solid var(--line); padding: 18px 20px; margin: 16px 0 24px; overflow-x: auto; line-height: 1.6; }
  .doc-main .code-block pre { margin: 0; }
  .doc-main pre code { background: transparent; border: 0; padding: 0; font-family: 'JetBrains Mono', monospace; }
  .doc-main pre code .line { display: block; }
  .doc-main pre.astro-code,
  .doc-main pre.astro-code span {
    color: var(--shiki-dark, inherit);
    background-color: var(--shiki-dark-bg, var(--bg-1));
    font-style: var(--shiki-dark-font-style);
    font-weight: var(--shiki-dark-font-weight);
    text-decoration: var(--shiki-dark-text-decoration);
  }
  [data-theme="light"] .doc-main pre.astro-code,
  [data-theme="light"] .doc-main pre.astro-code span {
    color: var(--shiki-light, inherit) !important;
    background-color: var(--shiki-light-bg, var(--bg-1)) !important;
    font-style: var(--shiki-light-font-style) !important;
    font-weight: var(--shiki-light-font-weight) !important;
    text-decoration: var(--shiki-light-text-decoration) !important;
  }

  /* Heading anchors (rehype-autolink-headings appends an <a class="heading-anchor">) */
  .doc-main h2, .doc-main h3 { position: relative; }
  .doc-main .heading-anchor {
    position: absolute; left: -22px; top: 50%; transform: translateY(-50%);
    color: var(--fg-muted); border: 0;
    font-family: 'JetBrains Mono', monospace; font-size: 0.8em;
    opacity: 0; transition: opacity .12s ease, color .12s ease;
    cursor: pointer; padding: 4px 6px; line-height: 1;
  }
  .doc-main h2:hover .heading-anchor,
  .doc-main h3:hover .heading-anchor,
  .doc-main .heading-anchor:focus { opacity: 1; }
  .doc-main .heading-anchor:hover { color: var(--accent); border-bottom: 0; }
  .doc-main .heading-anchor.copied { color: var(--green); }

  /* Code copy button (mounted by docs.client.ts) */
  .doc-main .copy-btn {
    position: absolute; top: 8px; right: 8px;
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: .08em; text-transform: uppercase;
    color: var(--fg-muted); background: var(--bg-2);
    border: 1px solid var(--line); padding: 4px 8px;
    opacity: 0; transition: opacity .12s ease, color .12s ease;
    cursor: pointer;
  }
  .doc-main .code-block:hover .copy-btn,
  .doc-main .copy-btn:focus { opacity: 1; }
  .doc-main .copy-btn:hover { color: var(--fg); }
  .doc-main .copy-btn.copied { color: var(--green); border-color: var(--green); }
  .doc-main ul { margin: 8px 0 20px 22px; color: var(--fg-dim); font-size: 15px; line-height: 1.7; }
  .doc-main a { color: var(--accent); border-bottom: 1px solid transparent; }
  .doc-main a:hover { border-bottom-color: var(--accent); }
  .doc-main blockquote {
    border: 1px solid var(--line-2); border-left: 3px solid var(--accent);
    padding: 14px 18px; margin: 18px 0 24px; background: var(--bg-1);
    font-size: 14px; color: var(--fg-dim); line-height: 1.6;
  }
  .doc-main blockquote p { margin-bottom: 0; }
  .doc-main table { width: 100%; margin: 16px 0 24px; border-collapse: collapse; font-size: 14px; }
  .doc-main th, .doc-main td { text-align: left; padding: 10px 14px; border-bottom: 1px solid var(--line); }
  .doc-main th { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: .08em; text-transform: uppercase; color: var(--fg-muted); font-weight: 500; }
  .doc-main td { color: var(--fg-dim); }
  .doc-main .doc-updated {
    margin-top: 48px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }

  .doc-toc { padding: 56px 24px; position: sticky; top: 56px; align-self: start; max-height: calc(100vh - 56px); overflow-y: auto; }
  .doc-toc h5 { font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: .12em; text-transform: uppercase; color: var(--fg-muted); margin-bottom: 14px; font-weight: 500; }
  .doc-toc a { display: block; padding: 5px 0; font-size: 12px; color: var(--fg-dim); border-left: 1px solid var(--line); padding-left: 12px; transition: color .12s ease, border-left-color .12s ease; }
  .doc-toc a.sub { padding-left: 24px; font-size: 11px; }
  .doc-toc a:hover { color: var(--fg); }
  .doc-toc a.active { color: var(--accent); border-left-color: var(--accent); }

  /* Collapsible widgets — desktop hides triggers; tablet/mobile show them. */
  .doc-collapse { display: none; }
  .doc-collapse .chev { transition: transform .15s ease; }
  .doc-collapse[aria-expanded="true"] .chev { transform: rotate(180deg); }
  .doc-toc-inline { display: none; }

  @media (max-width: 1100px) {
    .doc-toc { display: none; }
    .doc-layout { grid-template-columns: 240px 1fr; }
    .doc-toc-inline {
      display: block;
      margin: 0 0 32px;
      border: 1px solid var(--line);
      background: var(--bg-1);
    }
    .doc-toc-inline > .doc-collapse {
      display: flex;
      width: 100%;
      padding: 12px 16px;
      align-items: center; justify-content: space-between;
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px; letter-spacing: .1em; text-transform: uppercase;
      color: var(--fg-dim);
    }
    .doc-toc-inline-list { display: none; padding: 4px 16px 14px; }
    .doc-toc-inline > .doc-collapse[aria-expanded="true"] + .doc-toc-inline-list { display: block; }
    .doc-toc-inline-list a {
      display: block; padding: 4px 0; font-size: 12px; color: var(--fg-dim);
      border-left: 1px solid var(--line); padding-left: 12px;
    }
    .doc-toc-inline-list a.sub { padding-left: 24px; font-size: 11px; }
    .doc-toc-inline-list a:hover { color: var(--fg); }
    .doc-toc-inline-list a.active { color: var(--accent); border-left-color: var(--accent); }
  }

  @media (max-width: 800px) {
    .doc-layout { grid-template-columns: 1fr; }
    .doc-side {
      position: static; max-height: none; overflow: visible;
      border-right: 0; border-bottom: 1px solid var(--line);
      padding: 18px 20px 16px;
    }
    .doc-side > .doc-collapse {
      display: flex;
      width: 100%;
      margin-top: 4px;
      padding: 12px 0;
      align-items: center; justify-content: space-between;
      font-family: 'JetBrains Mono', monospace;
      font-size: 11px; letter-spacing: .1em; text-transform: uppercase;
      color: var(--fg-dim);
      border-top: 1px solid var(--line);
    }
    .doc-side > .doc-collapse[aria-expanded="false"] + .doc-side-nav { display: none; }
    .doc-main { padding: 32px 24px; }
  }

</style>

<script>
  import '../scripts/docs.client.ts';
</script>
