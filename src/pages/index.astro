---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../site.config';

const channelUpper = site.channel.toUpperCase();

const DL_BASE = `${site.github.mono}/releases/download/desktop-v${site.version}`;
// Linux arch tokens differ per electron-builder target:
//   AppImage → x86_64, deb → amd64, rpm → x86_64, tar.gz → x64.
// Keep in lock-step with packages/electron/package.json `linux.target` in tagma-mono.
const DL = {
  mac: `${DL_BASE}/Tagma-${site.version}-mac-arm64.dmg`,
  mac_x64: `${DL_BASE}/Tagma-${site.version}-mac-x64.dmg`,
  win: `${DL_BASE}/Tagma-${site.version}-win-x64.exe`,
  linux: `${DL_BASE}/Tagma-${site.version}-linux-x86_64.AppImage`,
  linux_deb: `${DL_BASE}/Tagma-${site.version}-linux-amd64.deb`,
  linux_rpm: `${DL_BASE}/Tagma-${site.version}-linux-x86_64.rpm`,
  linux_targz: `${DL_BASE}/Tagma-${site.version}-linux-x64.tar.gz`,
};
---

<BaseLayout title="Tagma — Every agent in formation.">

  <main>

    <section class="hero" id="download">
      <div class="eyebrow">
        <span class="square"></span>
        <span data-i18n="hero.eyebrow">§ TAGMA · DESKTOP EDITOR · v{site.version} {channelUpper}</span>
        <span class="bar"></span>
        <span style="color:var(--fg-dim)" data-i18n="hero.tagline">LOCAL-FIRST · PLUGIN-NATIVE</span>
      </div>

      <h1 data-i18n="hero.h1">
        <span>Every agent</span><br>
        <span class="nowrap">in <span class="accent">formation<span class="dot">.</span></span></span>
      </h1>

      <p class="hero-sub" data-i18n="hero.sub">
        A swim-lane editor for AI orchestration. <b>Task</b> is the atom — <b>prompt</b> or <b>command</b> — driven by the agent CLIs you already run: <b>Claude Code</b>, <b>Codex</b>, <b>OpenCode</b>, and anything you wire up through the SDK.
      </p>

      <div class="hero-meta">
        <span data-i18n="meta.size"><b>~{site.sizeMB} MB</b> · lightweight</span>
        <span class="pipe">│</span>
        <span data-i18n="meta.os"><b>{site.platforms.join(' · ')}</b></span>
        <span class="pipe">│</span>
        <span data-i18n="meta.lic"><b>{site.license}</b> core · TypeScript SDK</span>
      </div>

      <div class="hero-cta">
        <div class="dl-group">
          <div class="primary-wrap">
            <a class="primary" href={DL.mac} id="primaryDl">
              <span>↓</span><span data-i18n="dl.primary">Download for macOS</span>
              <span class="caret" id="primaryCaret">▾</span>
            </a>
            <div class="dl-menu" id="dlMenu" hidden>
              <a class="dl-menu-item" data-os="mac" data-menu-key="arm64" href={DL.mac} download>
                <span class="mi-label" data-i18n="dl.macArm">Apple Silicon</span>
                <span class="mi-arch">arm64</span>
              </a>
              <a class="dl-menu-item" data-os="mac" data-menu-key="x64" href={DL.mac_x64} download>
                <span class="mi-label" data-i18n="dl.macIntel">Intel</span>
                <span class="mi-arch">x64</span>
              </a>
              <a class="dl-menu-item" data-os="linux" data-menu-key="appimage" href={DL.linux} download>
                <span class="mi-label" data-i18n="dl.linuxAppImage">AppImage</span>
                <span class="mi-arch">x86_64</span>
              </a>
              <a class="dl-menu-item" data-os="linux" data-menu-key="deb" href={DL.linux_deb} download>
                <span class="mi-label" data-i18n="dl.linuxDeb">Debian · Ubuntu</span>
                <span class="mi-arch">.deb</span>
              </a>
              <a class="dl-menu-item" data-os="linux" data-menu-key="rpm" href={DL.linux_rpm} download>
                <span class="mi-label" data-i18n="dl.linuxRpm">Fedora · RHEL</span>
                <span class="mi-arch">.rpm</span>
              </a>
              <a class="dl-menu-item" data-os="linux" data-menu-key="targz" href={DL.linux_targz} download>
                <span class="mi-label" data-i18n="dl.linuxTarGz">Tarball</span>
                <span class="mi-arch">.tar.gz</span>
              </a>
            </div>
          </div>
          <a class="os active" data-os="mac"   href={DL.mac}><span class="os-icon"><svg viewBox="0 0 24 24"><path d="M17.05 12.53c-.03-3.02 2.47-4.47 2.58-4.54-1.41-2.06-3.6-2.34-4.38-2.37-1.86-.19-3.63 1.1-4.58 1.1-.94 0-2.4-1.07-3.94-1.04-2.03.03-3.9 1.18-4.94 3C-.33 11.36 1.25 17 3.28 20.09c1.01 1.51 2.21 3.21 3.79 3.15 1.52-.06 2.1-.98 3.94-.98 1.83 0 2.36.98 3.96.95 1.64-.03 2.67-1.54 3.67-3.06 1.16-1.76 1.64-3.47 1.66-3.56-.04-.02-3.19-1.22-3.22-4.86Zm-3.04-8.91c.84-1.02 1.4-2.43 1.25-3.84-1.21.05-2.67.8-3.53 1.81-.77.9-1.44 2.34-1.26 3.72 1.34.1 2.7-.68 3.54-1.69Z"/></svg></span>macOS</a>
          <a class="os"        data-os="win"   href={DL.win}><span class="os-icon"><svg viewBox="0 0 24 24"><path d="M3 3h8.5v8.5H3V3Zm9.5 0H21v8.5h-8.5V3ZM3 12.5h8.5V21H3v-8.5Zm9.5 0H21V21h-8.5v-8.5Z"/></svg></span>Windows</a>
          <a class="os"        data-os="linux" href={DL.linux}><span class="os-icon"><svg viewBox="0 0 24 24"><path d="M12 2c-2.2 0-3.5 1.9-3.5 4.3 0 1.4.4 2.4.9 3.3-1 .9-2 2.2-2.6 3.5-.6 1.3-1 2.8-1 4.1 0 .9.3 1.6.8 2.1-.4.4-.6 1-.6 1.6 0 1.1.9 1.8 2 1.8.6 0 1.1-.2 1.5-.5.5.5 1.3.8 2.5.8s2-.3 2.5-.8c.4.3.9.5 1.5.5 1.1 0 2-.7 2-1.8 0-.6-.2-1.2-.6-1.6.5-.5.8-1.2.8-2.1 0-1.3-.4-2.8-1-4.1-.6-1.3-1.6-2.6-2.6-3.5.5-.9.9-1.9.9-3.3C15.5 3.9 14.2 2 12 2Zm-1.2 4c.3 0 .5.3.5.7 0 .4-.2.8-.5.8s-.5-.4-.5-.8c0-.4.2-.7.5-.7Zm2.4 0c.3 0 .5.3.5.7 0 .4-.2.8-.5.8s-.5-.4-.5-.8c0-.4.2-.7.5-.7Z"/></svg></span>Linux</a>
        </div>
        <a class="docs-link" href="/docs"><span data-i18n="dl.docs">Read the docs</span><span>→</span></a>
      </div>
    </section>

    <div class="stage-wrap">
    <div class="stage">
      <div class="stage-chrome">
        <div class="sample-tabs" id="sampleTabs" role="tablist"></div>
        <span class="sp"></span>
        <span class="pill" data-role="reset">⟲ <span data-i18n="ed.reset">RESET</span></span>
        <span class="pill" data-role="yaml">&lt;/&gt; YAML</span>
        <span class="pill live"><span class="dot"></span>LIVE</span>
        <span class="pill run" data-role="run">▶ RUN</span>
      </div>

      <div class="canvas" id="canvas">
        <div class="lane-rail" id="laneRail"></div>

        <div class="lane-field" id="field">
          <svg id="wires"></svg>
        </div>

        <div class="minimap">
          <div class="minimap-h"><span>MINIMAP</span><span style="color:var(--fg-dim)">×</span></div>
          <div class="minimap-i">
            <div class="mm-lane" style="top:33.33%;"></div>
            <div class="mm-lane" style="top:66.66%;"></div>
            <div class="mm-block" style="left:4%;  top:8px;  width:18%; background:var(--teal);"></div>
            <div class="mm-block" style="left:24%; top:8px;  width:18%; background:var(--accent);"></div>
            <div class="mm-block" style="left:44%; top:8px;  width:18%; background:var(--line-2);"></div>
            <div class="mm-block" style="left:4%;  top:28px; width:18%; background:var(--green);"></div>
            <div class="mm-block" style="left:24%; top:28px; width:18%; background:var(--green);"></div>
            <div class="mm-block" style="left:70%; top:48px; width:18%; background:var(--pink); opacity:.7;"></div>
            <div class="mm-view"></div>
          </div>
        </div>

        <div class="zoom"><span>−</span><b>150%</b><span>+</span></div>
      </div>
    </div>
    </div>

    <section class="ways" id="ways">
      <div class="eyebrow">
        <span class="square"></span>
        <span data-i18n="ways.eyebrow">§ THREE WAYS TO RUN TAGMA</span>
        <span class="bar"></span>
        <span style="color:var(--fg-dim)" data-i18n="ways.tagline">EDITOR · SDK · CLI</span>
      </div>

      <div class="ways-grid">
        <div class="way">
          <div class="way-head"><span class="num">01</span><span data-i18n="ways.editor.kind">DESKTOP EDITOR</span></div>
          <h3 data-i18n="ways.editor.title">Tagma Editor</h3>
          <p data-i18n="ways.editor.desc">The full swim-lane UI — design, run, replay. The fastest way to see a pipeline working end-to-end.</p>
          <div class="way-install">
            <span class="prompt">↓</span>
            <code data-i18n="ways.editor.cmd">Download · macOS · Windows · Linux</code>
          </div>
          <div class="way-links">
            <a href="#download" data-i18n="ways.editor.link1">Download →</a>
            <a href="/docs" data-i18n="ways.editor.link2">Docs →</a>
          </div>
        </div>

        <div class="way">
          <div class="way-head"><span class="num">02</span><span data-i18n="ways.sdk.kind">TYPESCRIPT SDK</span></div>
          <h3>@tagma/sdk</h3>
          <p data-i18n="ways.sdk.desc">Build and run pipelines from your own code. The same runtime the editor uses — just imported as a library.</p>
          <div class="way-install">
            <span class="prompt">$</span>
            <code class="cmd">bun add @tagma/sdk</code>
            <button class="copy" data-copy="bun add @tagma/sdk">COPY</button>
          </div>
          <div class="way-links">
            <a href="https://www.npmjs.com/package/@tagma/sdk" target="_blank" rel="noopener">npm ↗</a>
            <a href="/docs" data-i18n="ways.sdk.link2">API docs →</a>
          </div>
        </div>

        <div class="way">
          <div class="way-head"><span class="num">03</span><span data-i18n="ways.cli.kind">COMMAND LINE</span></div>
          <h3>@tagma/cli</h3>
          <p data-i18n="ways.cli.desc">Run any <code style="font-family:inherit;color:var(--fg)">pipeline.yaml</code> from a shell. Ideal for CI, cron, or gluing agents into existing scripts.</p>
          <div class="way-install">
            <span class="prompt">$</span>
            <code class="cmd">bun add -g @tagma/cli</code>
            <button class="copy" data-copy="bun add -g @tagma/cli">COPY</button>
          </div>
          <div class="way-install">
            <span class="prompt">$</span>
            <code class="cmd">bunx @tagma/cli ./pipeline.yaml</code>
            <button class="copy" data-copy="bunx @tagma/cli ./pipeline.yaml">COPY</button>
          </div>
          <div class="way-links">
            <a href="https://www.npmjs.com/package/@tagma/cli" target="_blank" rel="noopener">npm ↗</a>
            <a href="/docs" data-i18n="ways.cli.link2">CLI docs →</a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <aside id="tweaks">
    <header><span>TWEAKS</span><span class="mono" style="color:var(--accent)">●</span></header>
    <div class="row">
      <label>Theme</label>
      <div class="seg" data-k="theme">
        <button data-v="dark">Dark</button>
        <button data-v="light">Light</button>
      </div>
    </div>
    <div class="row">
      <label>Language</label>
      <div class="seg" data-k="lang">
        <button data-v="en">EN</button>
        <button data-v="zh">中</button>
      </div>
    </div>
  </aside>

</BaseLayout>

<style is:global>
  .hero {
    max-width: 1360px; margin: 0 auto;
    padding: 64px 40px 32px;
    display: grid; grid-template-columns: minmax(0, 1fr); gap: 12px;
    border-bottom: 1px solid var(--line);
  }
  .eyebrow {
    display: flex; align-items: center; gap: 14px;
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    color: var(--fg-muted); letter-spacing: 0.1em; text-transform: uppercase;
    margin-bottom: 24px;
  }
  .eyebrow .square { width: 8px; height: 8px; background: var(--accent); }
  .eyebrow .bar { flex: 1; height: 1px; background: var(--line-2); max-width: 100px; }

  .hero h1 {
    font-size: clamp(48px, 8.4vw, 132px);
    line-height: 0.94;
    letter-spacing: -0.04em;
    font-weight: 500;
    overflow-wrap: normal;
    max-width: 18ch;
  }
  .hero h1 .accent { color: var(--accent); }
  .hero h1 .nowrap { white-space: nowrap; }
  .hero h1 .dot { color: var(--accent); }

  .hero-sub { margin-top: 36px; font-size: clamp(16px, 1.4vw, 19px); color: var(--fg-dim); max-width: 60ch; line-height: 1.5; }
  .hero-sub b { color: var(--fg); font-weight: 500; }
  .hero-sub .accent { color: var(--accent); font-weight: 500; }

  .hero-meta {
    margin-top: 28px;
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    color: var(--fg-muted); letter-spacing: 0.05em;
    display: flex; gap: 24px; flex-wrap: wrap; align-items: center;
    font-variant-numeric: tabular-nums;
  }
  .hero-meta b { color: var(--fg); font-weight: 500; }
  .hero-meta .pipe { color: var(--line-2); user-select: none; }

  .topbar, .stage-chrome, .lane-rail, .minimap, .zoom, .pill, .status, .eyebrow,
  .hero-meta, .dl-group .os, .docs-link, .chips, .glyph,
  .foot-base, #tweaks, .seg button { user-select: none; -webkit-user-select: none; }

  body { scrollbar-width: none; -ms-overflow-style: none; }
  body::-webkit-scrollbar { display: none; }
  .ways { max-width: 1360px; margin: 0 auto; padding: 72px 40px 48px; }
  .ways-grid {
    display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 0;
    border: 1px solid var(--line-2); margin-top: 32px;
  }
  .way { padding: 28px 26px 26px; border-right: 1px solid var(--line-2); display: flex; flex-direction: column; min-width: 0; }
  .way:last-child { border-right: 0; }
  .way-head {
    display: flex; align-items: baseline; gap: 10px;
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    color: var(--fg-dim); letter-spacing: .14em; text-transform: uppercase;
    user-select: none;
  }
  .way-head .num { color: var(--accent); }
  .way h3 { font-family: 'Space Grotesk', sans-serif; font-size: 28px; font-weight: 500; letter-spacing: -0.02em; margin: 12px 0 8px; }
  .way p { font-size: 13.5px; color: var(--fg-dim); line-height: 1.55; margin: 0 0 22px; min-height: 64px; }
  .way-install {
    border: 1px solid var(--line-2); background: var(--bg-1);
    padding: 10px 12px; font-family: 'JetBrains Mono', monospace; font-size: 12.5px;
    color: var(--fg); display: flex; align-items: center; gap: 10px;
    margin-bottom: 8px;
  }
  .way-install .prompt { color: var(--fg-muted); user-select: none; }
  .way-install code { flex: 1; overflow-x: auto; white-space: nowrap; }
  body { user-select: none; -webkit-user-select: none; }
  .way-install code.cmd { user-select: text; -webkit-user-select: text; cursor: text; }
  .way-install .copy {
    font-size: 10px; letter-spacing: .1em; color: var(--fg-dim);
    border: 1px solid var(--line-2); padding: 3px 8px; cursor: pointer;
    user-select: none; background: transparent;
  }
  .way-install .copy:hover { color: var(--accent); border-color: var(--accent); }
  .way-links { margin-top: auto; padding-top: 22px; display: flex; gap: 14px; font-size: 12px; }
  .way-links a { color: var(--fg-dim); text-decoration: none; border-bottom: 1px solid var(--line-2); padding-bottom: 2px; }
  .way-links a:hover { color: var(--accent); border-color: var(--accent); }
  @media (max-width: 900px) {
    .ways { padding: 48px 24px; }
    .ways-grid { grid-template-columns: 1fr; }
    .way { border-right: 0; border-bottom: 1px solid var(--line-2); }
    .way:last-child { border-bottom: 0; }
    .way p { min-height: 0; }
  }

  .hero-cta { margin-top: 36px; display: flex; gap: 14px; flex-wrap: wrap; align-items: stretch; }
  .dl-group { display: inline-flex; align-items: stretch; border: 1px solid var(--line-2); height: 50px; }
  .dl-group .primary {
    background: var(--accent); color: var(--accent-ink);
    padding: 0 24px; font-weight: 600; font-size: 14px;
    display: inline-flex; align-items: center; gap: 10px;
    border-right: 1px solid var(--accent-ink);
  }
  [data-theme="light"] .dl-group .primary { color: #fff; }
  .dl-group .primary:hover { background: #ff8a3d; }
  .primary-wrap { position: relative; display: inline-flex; }
  .dl-group .primary .caret {
    font-size: 10px; line-height: 1; opacity: .8; margin-left: 2px;
    display: none;
  }
  .primary-wrap.has-menu .dl-group .primary .caret,
  .dl-group .primary.has-menu .caret { display: inline; }
  .dl-menu {
    position: absolute; left: 0; top: calc(100% + 4px);
    min-width: 100%;
    background: var(--bg); border: 1px solid var(--line-2);
    display: flex; flex-direction: column;
    z-index: 50;
  }
  .dl-menu[hidden] { display: none; }
  .dl-menu-item {
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    padding: 10px 14px;
    color: var(--fg); text-decoration: none;
    font-size: 13px; font-weight: 500;
    border-bottom: 1px solid var(--line);
    transition: background .1s, color .1s;
  }
  .dl-menu-item:last-child { border-bottom: 0; }
  .dl-menu-item[hidden] { display: none; }
  .dl-menu-item:hover { background: var(--bg-1); color: var(--accent); }
  .dl-menu-item .mi-arch {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    color: var(--fg-muted); letter-spacing: .05em;
  }
  .dl-menu-item:hover .mi-arch { color: var(--accent); }
  .dl-group .os {
    padding: 0 16px; font-family: 'JetBrains Mono', monospace; font-size: 12px;
    color: var(--fg-dim); border-left: 1px solid var(--line-2);
    display: inline-flex; align-items: center; gap: 8px;
    transition: background .12s, color .12s;
    position: relative;
  }
  .dl-group .os:first-of-type { border-left: 0; }
  .dl-group .os:hover { color: var(--fg); background: var(--bg-1); }
  .dl-group .os.active { color: var(--accent); }
  .dl-group .os.active::after { content: ""; position: absolute; left: 0; right: 0; bottom: -1px; height: 2px; background: var(--accent); }
  .dl-group .os .os-icon { width: 12px; height: 12px; display: inline-flex; }
  .dl-group .os .os-icon svg { width: 100%; height: 100%; fill: currentColor; }

  .docs-link {
    display: inline-flex; align-items: center; gap: 8px;
    height: 50px; padding: 0 18px;
    border: 1px solid var(--line-2);
    font-size: 13px; color: var(--fg-dim);
  }
  .docs-link:hover { color: var(--fg); border-color: var(--fg-muted); }

  .stage-wrap {
    background: var(--bg-1);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: 72px 40px;
    display: flex; align-items: center; justify-content: center;
    min-height: 640px;
  }
  [data-theme="light"] .stage-wrap { background: #fafaf7; }
  .stage { width: 100%; max-width: 1280px; margin: 0; border: 1px solid var(--line-2); background: var(--bg-1); overflow: hidden; position: relative; }
  .stage-chrome {
    display: flex; align-items: center; gap: 12px;
    padding: 9px 14px;
    border-bottom: 1px solid var(--line);
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    color: var(--fg-muted);
    background: var(--bg);
    white-space: nowrap; overflow: hidden;
  }
  .stage-chrome .crumb { color: var(--fg-dim); display: inline-flex; align-items: center; gap: 8px; }
  .stage-chrome .crumb b { color: var(--fg); font-weight: 500; }
  .stage-chrome .sp { flex: 1; }
  .stage-chrome .pill { border: 1px solid var(--line-2); padding: 3px 8px; color: var(--fg-dim); display: inline-flex; align-items: center; gap: 6px; }
  .stage-chrome .pill.live { color: var(--green); border-color: color-mix(in srgb, var(--green) 35%, var(--line-2)); }
  .stage-chrome .pill.live .dot { width: 6px; height: 6px; background: var(--green); border-radius: 50%; box-shadow: 0 0 8px var(--green); animation: pulse 1.6s ease-in-out infinite; }
  @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: .3; } }
  .stage-chrome .pill.run { background: var(--accent); color: var(--accent-ink); border-color: var(--accent); font-weight: 600; }
  [data-theme="light"] .stage-chrome .pill.run { color: #fff; }

  .canvas { position: relative; height: 420px; background-image: radial-gradient(circle, var(--line-2) 1px, transparent 1px); background-size: 22px 22px; background-color: var(--bg-1); overflow: hidden; }
  .lane-rail { position: absolute; left: 0; top: 0; bottom: 0; width: 152px; background: var(--bg); border-right: 1px solid var(--line); display: flex; flex-direction: column; }
  .lane-rail .lane-row { flex: 1; padding: 12px 14px; border-bottom: 1px solid var(--line); position: relative; display: flex; flex-direction: column; gap: 5px; }
  .lane-rail .lane-row:last-child { border-bottom: 0; }
  .lane-rail .lane-name { display: flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 500; }
  .lane-rail .lane-name .swatch { width: 10px; height: 10px; }
  .lane-rail .lane-meta { font-family: 'JetBrains Mono', monospace; font-size: 9px; color: var(--fg-muted); letter-spacing: 0.04em; font-variant-numeric: tabular-nums; }
  .lane-rail .cnt { position: absolute; right: 12px; top: 12px; font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--fg-muted); font-variant-numeric: tabular-nums; }

  .lane-field { position: absolute; left: 152px; right: 0; top: 0; bottom: 0; }
  .lane-strip { position: absolute; left: 0; right: 0; border-bottom: 1px solid var(--line); }

  .task {
    position: absolute; width: 186px;
    background: var(--panel);
    border: 1px solid var(--line-2);
    border-left-width: 3px;
    padding: 8px 10px 10px;
    display: flex; flex-direction: column; gap: 4px;
    z-index: 2;
    transition: border-color .25s, box-shadow .25s, transform .25s cubic-bezier(.6,.1,.2,1);
  }
  .task .t1 { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--fg); font-weight: 500; }
  .task .t1 .title { flex: 1; min-width: 0; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
  .task .t1 .glyph { font-size: 10px; color: var(--fg-muted); flex-shrink: 0; }
  .task .t1 .status { flex-shrink: 0; font-family: 'JetBrains Mono', monospace; font-size: 9px; color: var(--fg-muted); font-variant-numeric: tabular-nums; }
  .task .t1 .status.ok { color: var(--green); }
  .task .t1 .status.run { color: var(--accent); }
  .task .t2 { display: flex; align-items: center; gap: 5px; font-family: 'JetBrains Mono', monospace; font-size: 9px; color: var(--fg-muted); letter-spacing: 0.03em; }
  .task .t2 .driver { color: var(--fg-dim); }
  .task .t2 .chips { display: flex; gap: 3px; margin-left: auto; }
  .task .t2 .chip { width: 6px; height: 6px; background: var(--fg-muted); }
  .task .t2 .chip.r { background: var(--accent); }
  .task .t2 .chip.g { background: var(--green); }
  .task .t2 .chip.y { background: var(--warn); }
  .task .t2 .chip.b { background: var(--blue); }

  .task[data-color="teal"]   { border-left-color: var(--teal); }
  .task[data-color="green"]  { border-left-color: var(--green); }
  .task[data-color="orange"] { border-left-color: var(--accent); }
  .task[data-color="pink"]   { border-left-color: var(--pink); }
  .task[data-color="blue"]   { border-left-color: var(--blue); }
  .task[data-color="muted"]  { border-left-color: var(--line-2); }

  .task.running { box-shadow: 0 0 0 1px var(--accent), 0 0 28px -6px var(--accent); border-color: var(--accent); }
  .task.running::after {
    content: ""; position: absolute; left: 0; right: 0; bottom: 0; height: 2px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    background-size: 50% 100%;
    animation: sweep 1.6s linear infinite;
  }
  @keyframes sweep { 0% { background-position: -100% 0; } 100% { background-position: 200% 0; } }
  .task.queued  { opacity: .55; }
  .task:hover:not(.running) { border-color: var(--fg-muted); }

  #wires { position: absolute; left: 0; right: 0; top: 0; bottom: 0; pointer-events: none; z-index: 1; }
  #wires path { fill: none; stroke: var(--line-2); stroke-width: 1.25; }
  #wires path.pending { stroke: var(--fg-muted); stroke-dasharray: 3 3; opacity: .7; }
  #wires path.active  { stroke: var(--accent); stroke-dasharray: 5 3; animation: dash 0.55s linear infinite; }
  @keyframes dash { to { stroke-dashoffset: -16; } }

  .minimap { position: absolute; right: 12px; bottom: 12px; width: 210px; height: 96px; background: var(--bg); border: 1px solid var(--line-2); padding: 8px; }
  .minimap-h { display: flex; justify-content: space-between; align-items: center; font-family: 'JetBrains Mono', monospace; font-size: 9px; color: var(--fg-muted); letter-spacing: 0.1em; margin-bottom: 6px; }
  .minimap-i { position: relative; height: 64px; background: var(--bg-2); border: 1px solid var(--line); overflow: hidden; }
  .minimap-i .mm-lane { position: absolute; left: 0; right: 0; height: 1px; background: var(--line); }
  .mm-block { position: absolute; height: 8px; }
  .mm-view { position: absolute; border: 1px solid var(--accent); opacity: .5; pointer-events: none; left: 2%; right: 2%; top: 2px; bottom: 2px; }

  .zoom { position: absolute; left: 12px; bottom: 12px; display: flex; gap: 8px; align-items: center; font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--fg-muted); }
  .zoom b { color: var(--fg); }

  #tweaks { position: fixed; right: 20px; bottom: 20px; z-index: 100; display: none; background: var(--bg); border: 1px solid var(--line-2); width: 240px; }
  #tweaks.show { display: block; }
  #tweaks header { display: flex; align-items: center; justify-content: space-between; padding: 10px 14px; border-bottom: 1px solid var(--line); font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--fg); }
  #tweaks .row { display: flex; align-items: center; justify-content: space-between; padding: 12px 14px; border-bottom: 1px solid var(--line); }
  #tweaks .row:last-child { border-bottom: 0; }
  #tweaks .row label { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--fg-dim); text-transform: uppercase; letter-spacing: 0.06em; }
  #tweaks .seg { display: inline-flex; border: 1px solid var(--line-2); }
  #tweaks .seg button { padding: 5px 10px; font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--fg-dim); border-right: 1px solid var(--line-2); }
  #tweaks .seg button:last-child { border-right: 0; }
  #tweaks .seg button.active { background: var(--accent); color: var(--accent-ink); }

  @media (max-width: 960px) {
    .topnav { display: none; }
    .hero { padding: 40px 24px 24px; }
    .stage-wrap { padding: 40px 24px; min-height: 0; }
    .stage { margin: 0; max-width: none; }
    .canvas { height: 360px; }
    .foot { grid-template-columns: 1fr 1fr; gap: 24px; padding: 28px 24px; }
    .docs-link { display: none; }
  }

  .sample-tabs {
    display: flex; gap: 0; flex: 1; min-width: 0;
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    letter-spacing: 0.08em; text-transform: uppercase;
    overflow-x: auto; scrollbar-width: none;
  }
  .sample-tabs::-webkit-scrollbar { display: none; }
  .sample-tab {
    padding: 4px 12px; color: var(--fg-dim); cursor: pointer;
    border: 0; background: transparent;
    border-bottom: 2px solid transparent;
    white-space: nowrap; user-select: none;
    font: inherit; text-transform: inherit; letter-spacing: inherit;
    transition: color .12s, border-color .12s;
  }
  .sample-tab:hover { color: var(--fg); }
  .sample-tab.active { color: var(--accent); border-bottom-color: var(--accent); }
  .stage-chrome .pill { cursor: pointer; }
  .stage-chrome .pill[data-role="yaml"].active { background: var(--fg); color: var(--bg); border-color: var(--fg); }
  [data-theme="light"] .stage-chrome .pill[data-role="yaml"].active { color: var(--bg); }

  /* blocked state + approve button */
  .task.blocked { border-color: var(--warn); box-shadow: 0 0 0 1px var(--warn), 0 0 20px -8px var(--warn); }
  .task.blocked .glyph { color: var(--warn); }
  .task .t1 .status.warn { color: var(--warn); }
  .approve-btn {
    margin-left: 6px; flex-shrink: 0;
    font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 0.08em;
    padding: 2px 8px; background: var(--accent); color: var(--accent-ink);
    border: 0; cursor: pointer; font-weight: 600;
  }
  [data-theme="light"] .approve-btn { color: #fff; }
  .approve-btn:hover { background: #ff8a3d; }
  .approve-btn .countdown { font-weight: 400; opacity: .75; }
</style>

<script>
  interface Tweaks { theme: 'dark' | 'light'; lang: 'en' | 'zh' }
  interface TagmaShell { persist(p: Partial<Tweaks>): void; get(): Tweaks; apply(): void }
  declare global { interface Window { TAGMA_SHELL?: TagmaShell } }

  const DL_LABELS: Record<string, Record<string, string>> = {
    en: { mac: 'Download for macOS', win: 'Download for Windows', linux: 'Download for Linux' },
    zh: { mac: '下载 macOS 版',        win: '下载 Windows 版',       linux: '下载 Linux 版' },
  };
  const MENU_LABELS: Record<string, Record<string, string>> = {
    en: {
      arm64: 'Apple Silicon', x64: 'Intel',
      appimage: 'AppImage', deb: 'Debian · Ubuntu', rpm: 'Fedora · RHEL', targz: 'Tarball',
    },
    zh: {
      arm64: 'Apple Silicon', x64: 'Intel',
      appimage: 'AppImage', deb: 'Debian · Ubuntu', rpm: 'Fedora · RHEL', targz: '压缩包',
    },
  };

  const OS_WITH_MENU = new Set(['mac', 'linux']);

  function updatePrimaryDl() {
    const tw = window.TAGMA_SHELL?.get() ?? { theme: 'dark' as const, lang: 'en' as const };
    const active = document.querySelector<HTMLAnchorElement>('.dl-group .os.active');
    const os = active?.dataset.os ?? 'mac';
    const dict = DL_LABELS[tw.lang] ?? DL_LABELS.en;
    const label = dict[os] ?? dict.mac;
    const span = document.querySelector<HTMLElement>('#primaryDl span[data-i18n], #primaryDl span:nth-child(2)');
    if (span) span.textContent = label;
    const primary = document.querySelector<HTMLAnchorElement>('#primaryDl');
    if (primary && active?.href) primary.href = active.href;
    const wrap = document.querySelector<HTMLElement>('.primary-wrap');
    const hasMenu = OS_WITH_MENU.has(os);
    wrap?.classList.toggle('has-menu', hasMenu);
    if (!hasMenu) document.getElementById('dlMenu')?.setAttribute('hidden', '');
    // Show only menu items belonging to the active OS.
    document.querySelectorAll<HTMLAnchorElement>('.dl-menu-item').forEach((el) => {
      const itemOs = el.dataset.os ?? '';
      if (itemOs === os) el.removeAttribute('hidden');
      else el.setAttribute('hidden', '');
    });
    const menuDict = MENU_LABELS[tw.lang] ?? MENU_LABELS.en;
    document.querySelectorAll<HTMLElement>('.dl-menu-item .mi-label').forEach((el) => {
      const key = el.parentElement?.getAttribute('data-menu-key') ?? '';
      el.textContent = menuDict[key] ?? el.textContent ?? '';
    });
  }

  (function setupMacMenu() {
    const primary = document.getElementById('primaryDl');
    const menu = document.getElementById('dlMenu');
    const wrap = document.querySelector<HTMLElement>('.primary-wrap');
    if (!primary || !menu || !wrap) return;
    primary.addEventListener('click', (e) => {
      if (!wrap.classList.contains('has-menu')) return;
      e.preventDefault();
      const open = !menu.hasAttribute('hidden');
      if (open) menu.setAttribute('hidden', '');
      else menu.removeAttribute('hidden');
    });
    document.addEventListener('click', (e) => {
      if (menu.hasAttribute('hidden')) return;
      if (!wrap.contains(e.target as Node)) menu.setAttribute('hidden', '');
    });
    menu.querySelectorAll<HTMLAnchorElement>('.dl-menu-item').forEach((a) => {
      a.addEventListener('click', () => menu.setAttribute('hidden', ''));
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') menu.setAttribute('hidden', '');
    });
  })();

  document.getElementById('tweaks')?.querySelectorAll<HTMLElement>('.seg').forEach((g) => {
    g.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('button');
      if (!btn) return;
      const k = g.dataset.k;
      const v = (btn as HTMLElement).dataset.v;
      if (k && v && window.TAGMA_SHELL) window.TAGMA_SHELL.persist({ [k]: v } as Partial<Tweaks>);
    });
  });

  document.addEventListener('tagma:apply', (ev) => {
    const tw = (ev as CustomEvent).detail ?? {};
    document.querySelectorAll<HTMLElement>('#tweaks [data-k]').forEach((group) => {
      const k = group.dataset.k;
      group.querySelectorAll<HTMLButtonElement>('button').forEach((b) => {
        b.classList.toggle('active', Boolean(k && b.dataset.v === String((tw as Record<string, unknown>)[k])));
      });
    });
    updatePrimaryDl();
  });

  document.querySelectorAll<HTMLAnchorElement>('.dl-group .os').forEach((el) => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      document.querySelectorAll<HTMLAnchorElement>('.dl-group .os').forEach((x) => x.classList.remove('active'));
      el.classList.add('active');
      updatePrimaryDl();
    });
  });

  document.querySelectorAll<HTMLButtonElement>('.way-install .copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy ?? '';
      try { await navigator.clipboard.writeText(text); } catch { /* ignore */ }
      const old = btn.textContent;
      const lang = window.TAGMA_SHELL?.get().lang ?? 'en';
      btn.textContent = lang === 'zh' ? '已复制' : 'COPIED';
      btn.style.color = 'var(--accent)';
      btn.style.borderColor = 'var(--accent)';
      setTimeout(() => { btn.textContent = old; btn.style.color = ''; btn.style.borderColor = ''; }, 1200);
    });
  });

  (function () {
    const ua = navigator.userAgent;
    let os: 'mac' | 'win' | 'linux' = 'mac';
    if (/Windows/i.test(ua)) os = 'win';
    else if (/Linux/i.test(ua) && !/Android/i.test(ua)) os = 'linux';
    else if (/Mac|iPhone|iPad/i.test(ua)) os = 'mac';
    document.querySelectorAll<HTMLElement>('.dl-group .os').forEach((b) => {
      b.classList.toggle('active', b.dataset.os === os);
    });
  })();
  updatePrimaryDl();

  import { SAMPLES, DEFAULT_SAMPLE_ID } from '../lib/demo/samples';
  import { mount, type Controller, type ReplayRoots } from '../lib/demo/replay';

  function demoRoots(): ReplayRoots | null {
    const canvas = document.getElementById('canvas');
    const rail = document.getElementById('laneRail');
    const field = document.getElementById('field');
    const wires = document.getElementById('wires') as unknown as SVGSVGElement | null;
    if (!canvas || !rail || !field || !wires) return null;
    return { canvas, rail, field, wires };
  }

  let currentCtrl: Controller | null = null;

  function renderTabs(activeId: string) {
    const host = document.getElementById('sampleTabs');
    if (!host) return;
    const lang = (window as Window & { TAGMA_SHELL?: { get(): { lang: 'en' | 'zh' } } }).TAGMA_SHELL?.get().lang ?? 'en';
    host.innerHTML = '';
    SAMPLES.forEach((s) => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'sample-tab' + (s.id === activeId ? ' active' : '');
      btn.dataset.sampleId = s.id;
      btn.setAttribute('role', 'tab');
      btn.textContent = s.tabLabel[lang];
      host.appendChild(btn);
    });
  }

  function switchSample(id: string) {
    const roots = demoRoots();
    if (!roots) return;
    const sample = SAMPLES.find((s) => s.id === id) ?? SAMPLES[0];
    if (currentCtrl) currentCtrl.destroy();
    currentCtrl = mount(roots, sample);
    renderTabs(sample.id);
  }

  window.addEventListener('load', () => switchSample(DEFAULT_SAMPLE_ID));
  if (document.readyState === 'complete') switchSample(DEFAULT_SAMPLE_ID);

  document.getElementById('sampleTabs')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLElement>('.sample-tab');
    if (!btn || !btn.dataset.sampleId) return;
    if (currentCtrl?.sampleId === btn.dataset.sampleId) return;
    switchSample(btn.dataset.sampleId);
  });

  document.addEventListener('tagma:apply', () => {
    if (currentCtrl) renderTabs(currentCtrl.sampleId);
  });

  document.getElementById('field')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLElement>('[data-role="approve"]');
    if (!btn) return;
    currentCtrl?.approve();
  });

  document.querySelector('.stage-chrome')?.addEventListener('click', (e) => {
    const pill = (e.target as HTMLElement).closest<HTMLElement>('.pill[data-role]');
    if (!pill || !currentCtrl) return;
    const role = pill.dataset.role;
    if (role === 'run') currentCtrl.reset();
    else if (role === 'reset') { currentCtrl.reset(); currentCtrl.pause(); }
  });

  window.addEventListener('message', (ev) => {
    const d = (ev.data ?? {}) as { type?: string };
    if (d.type === '__activate_edit_mode') document.getElementById('tweaks')?.classList.add('show');
    if (d.type === '__deactivate_edit_mode') document.getElementById('tweaks')?.classList.remove('show');
  });
  try { window.parent.postMessage({ type: '__edit_mode_available' }, '*'); } catch { /* ignore */ }
</script>
