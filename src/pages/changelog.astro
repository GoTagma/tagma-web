---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const entries = await getCollection('changelog');
entries.sort((a, b) => b.data.date.localeCompare(a.data.date));

const rendered = await Promise.all(entries.map(async (e) => ({ entry: e, ...(await render(e)) })));

function fmtDate(iso: string): string {
  const d = new Date(iso + 'T00:00:00Z');
  const months = ['JAN', 'FEB', 'MAR', 'APR', 'MAY', 'JUN', 'JUL', 'AUG', 'SEP', 'OCT', 'NOV', 'DEC'];
  const mm = months[d.getUTCMonth()];
  const dd = String(d.getUTCDate()).padStart(2, '0');
  const yy = d.getUTCFullYear();
  return `${mm} ${dd}, ${yy}`;
}

function channelLabel(ch: string): string {
  const m: Record<string, string> = {
    alpha: 'ALPHA', beta: 'BETA', rc: 'RC', stable: 'MINOR', patch: 'PATCH',
  };
  return m[ch] ?? ch.toUpperCase();
}
---

<BaseLayout title="Tagma — Changelog" description="Release notes for Tagma.">
  <main>
    <section class="page-head">
      <div class="page-eyebrow"><span class="square"></span><span>§ TAGMA · CHANGELOG</span><span class="bar"></span><span style="color:var(--fg-dim)">RELEASES &amp; NOTES</span></div>
      <h1>Release <span class="accent">notes<span style="color:var(--accent)">.</span></span></h1>
      <p class="lede">Every version of Tagma, what shipped and what broke. Signed builds, reproducible hashes, no surprises.</p>
    </section>

    <div class="log-wrap">
      <div class="filter-bar">
        <span class="chip active">All</span>
        <span class="chip">Major</span>
        <span class="chip">Minor</span>
        <span class="chip">Patch</span>
        <span class="chip">Pre-release</span>
        <span class="sep"></span>
        <input type="text" placeholder="> filter versions..." />
      </div>

      {rendered.map(({ entry, Content }) => (
        <div class="release" data-channel={entry.data.channel}>
          <div class="side">
            <div class="ver">
              v{entry.data.version}
              <span class={`tag ${entry.data.channel}`}>{channelLabel(entry.data.channel)}</span>
            </div>
            <div class="date">{fmtDate(entry.data.date)}</div>
            {entry.data.sha && <div class="sha">SHA256<br />{entry.data.sha}</div>}
          </div>
          <div class="body">
            <h2>{entry.data.summary.split(' — ')[0]}</h2>
            {entry.data.summary.includes(' — ') && (
              <p class="sum">{entry.data.summary.split(' — ').slice(1).join(' — ')}</p>
            )}
            <Content />
          </div>
        </div>
      ))}
    </div>
  </main>
</BaseLayout>

<style is:global>
  .page-head {
    max-width: 1360px; margin: 0 auto;
    padding: 64px 40px 40px;
    border-bottom: 1px solid var(--line);
  }
  .page-eyebrow {
    display: flex; align-items: center; gap: 14px;
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    color: var(--fg-muted); letter-spacing: 0.1em; text-transform: uppercase;
    margin-bottom: 24px;
  }
  .page-eyebrow .square { width: 8px; height: 8px; background: var(--accent); }
  .page-eyebrow .bar { flex: 1; height: 1px; background: var(--line-2); max-width: 100px; }
  .page-head h1 {
    font-size: clamp(48px, 8vw, 108px);
    line-height: 0.94; letter-spacing: -0.04em; font-weight: 500;
    max-width: 18ch;
  }
  .page-head h1 .accent { color: var(--accent); }
  .page-head .lede { margin-top: 28px; font-size: 17px; color: var(--fg-dim); max-width: 60ch; line-height: 1.55; }

  .log-wrap { padding: 0 40px 80px; max-width: 1360px; margin: 0 auto; }
  .filter-bar {
    display: flex; gap: 10px; padding: 20px 0; border-bottom: 1px solid var(--line);
    font-family: 'JetBrains Mono', monospace; font-size: 11px; align-items: center;
    flex-wrap: wrap;
  }
  .filter-bar .chip { padding: 5px 10px; border: 1px solid var(--line-2); color: var(--fg-dim); cursor: pointer; letter-spacing: .05em; text-transform: uppercase; }
  .filter-bar .chip:hover { color: var(--fg); }
  .filter-bar .chip.active { background: var(--fg); color: var(--bg); border-color: var(--fg); }
  .filter-bar .sep { flex: 1; }
  .filter-bar input { height: 30px; padding: 0 12px; background: transparent; border: 1px solid var(--line-2); color: var(--fg); font: inherit; font-family: 'JetBrains Mono', monospace; font-size: 12px; width: 220px; }

  .release {
    display: grid; grid-template-columns: 160px minmax(0, 1fr);
    gap: 40px; padding: 48px 0; border-bottom: 1px solid var(--line);
  }
  .release:last-child { border-bottom: 0; }
  .release .side { position: sticky; top: 76px; align-self: start; }
  .release .ver { font-family: 'JetBrains Mono', monospace; font-size: 13px; color: var(--fg); font-weight: 600; letter-spacing: .02em; }
  .release .ver .tag { margin-left: 6px; padding: 2px 6px; font-size: 9px; font-weight: 500; background: var(--accent); color: var(--accent-ink); letter-spacing: .08em; vertical-align: 2px; }
  [data-theme="light"] .release .ver .tag { color: #fff; }
  .release .ver .tag.beta  { background: var(--blue); }
  .release .ver .tag.patch { background: var(--green); }
  .release .ver .tag.rc    { background: var(--warn); }
  .release .ver .tag.alpha { background: var(--pink); }
  .release .date { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--fg-muted); margin-top: 6px; letter-spacing: .05em; }
  .release .sha { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--fg-muted); margin-top: 14px; border-top: 1px solid var(--line); padding-top: 10px; }

  .release .body h2 { font-size: 28px; font-weight: 500; letter-spacing: -.02em; margin-bottom: 10px; }
  .release .body .sum { color: var(--fg-dim); font-size: 15px; line-height: 1.6; margin-bottom: 20px; max-width: 64ch; }
  .release .body > p { color: var(--fg-dim); font-size: 15px; line-height: 1.6; margin-bottom: 20px; max-width: 64ch; }
  .release .body h3 {
    font-family: 'JetBrains Mono', monospace; font-size: 10px; letter-spacing: .12em;
    text-transform: uppercase; color: var(--fg-muted); margin-top: 22px; margin-bottom: 10px; font-weight: 500;
    display: flex; align-items: center; gap: 10px;
  }
  .release .body h3::before { content: ""; width: 8px; height: 8px; background: var(--accent); }
  .release .body ul { list-style: none; padding-left: 0; }
  .release .body li {
    padding: 8px 0 8px 16px; border-bottom: 1px solid var(--line);
    font-size: 14px; color: var(--fg-dim); line-height: 1.55;
    position: relative;
  }
  .release .body li::before { content: "›"; position: absolute; left: 0; color: var(--fg-muted); font-family: 'JetBrains Mono', monospace; }
  .release .body li strong, .release .body li b { color: var(--fg); font-weight: 500; }
  .release .body code { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--fg); background: var(--bg-1); padding: 1px 5px; border: 1px solid var(--line); }

  @media (max-width: 800px) {
    .log-wrap { padding: 0 24px 40px; }
    .release { grid-template-columns: 1fr; gap: 16px; padding: 32px 0; }
    .release .side { position: static; }
  }

  body { user-select: none; -webkit-user-select: none; }
</style>
