---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../site.config';

const entries = await getCollection('archive');

function compareVersion(a: string, b: string): number {
  const pa = a.split('.').map((n) => parseInt(n, 10) || 0);
  const pb = b.split('.').map((n) => parseInt(n, 10) || 0);
  const len = Math.max(pa.length, pb.length);
  for (let i = 0; i < len; i++) {
    const diff = (pa[i] ?? 0) - (pb[i] ?? 0);
    if (diff !== 0) return diff;
  }
  return 0;
}

entries.sort((a, b) => {
  const byDate = b.data.date.localeCompare(a.data.date);
  if (byDate !== 0) return byDate;
  return compareVersion(b.data.version, a.data.version);
});

// Filename pattern mirrors `artifactName` in packages/electron/package.json:
// `Tagma-<version>-<os>-<arch>.<ext>`. Each Linux target uses a different
// arch token (AppImage/rpm → x86_64, deb → amd64, tar.gz → x64) — keep this
// in lock-step with packages/electron/package.json `linux.target`.
type AssetItem = { label: string; arch: string; slug: string; ext: string };
type Platform = { os: 'mac' | 'win' | 'linux'; label: string; items: AssetItem[] };

const PLATFORMS: Platform[] = [
  {
    os: 'mac', label: 'macOS',
    items: [
      { label: 'Apple Silicon', arch: 'arm64', slug: 'mac-arm64', ext: 'dmg' },
      { label: 'Intel',         arch: 'x64',   slug: 'mac-x64',   ext: 'dmg' },
    ],
  },
  {
    os: 'win', label: 'Windows',
    items: [
      { label: 'Windows', arch: 'x64', slug: 'win-x64', ext: 'exe' },
    ],
  },
  {
    os: 'linux', label: 'Linux',
    items: [
      { label: 'AppImage',        arch: 'x86_64',  slug: 'linux-x86_64', ext: 'AppImage' },
      { label: 'Debian · Ubuntu', arch: '.deb',    slug: 'linux-amd64',  ext: 'deb' },
      { label: 'Fedora · RHEL',   arch: '.rpm',    slug: 'linux-x86_64', ext: 'rpm' },
      { label: 'Tarball',         arch: '.tar.gz', slug: 'linux-x64',    ext: 'tar.gz' },
    ],
  },
];

function downloadUrl(version: string, slug: string, ext: string): string {
  return `${site.github.mono}/releases/download/desktop-v${version}/Tagma-${version}-${slug}.${ext}`;
}

function fmtDate(iso: string): string {
  const d = new Date(iso + 'T00:00:00Z');
  const months = ['JAN', 'FEB', 'MAR', 'APR', 'MAY', 'JUN', 'JUL', 'AUG', 'SEP', 'OCT', 'NOV', 'DEC'];
  return `${months[d.getUTCMonth()]} ${String(d.getUTCDate()).padStart(2, '0')}, ${d.getUTCFullYear()}`;
}

function channelLabel(ch: string): string {
  const m: Record<string, string> = {
    alpha: 'ALPHA', beta: 'BETA', rc: 'RC', stable: 'STABLE', patch: 'PATCH',
  };
  return m[ch] ?? ch.toUpperCase();
}
---

<BaseLayout title="Tagma — Archive" description="Every released build of Tagma. Direct download links for all platforms.">
  <main>
    <section class="page-head">
      <div class="page-eyebrow"><span class="square"></span><span>§ TAGMA · ARCHIVE</span><span class="bar"></span><span style="color:var(--fg-dim)">HISTORICAL BUILDS</span></div>
      <h1>Version <span class="accent">archive<span style="color:var(--accent)">.</span></span></h1>
      <p class="lede">Every released build of Tagma. Pick a platform to download directly.</p>
    </section>

    <div class="arc-wrap">
      <div class="filter-bar">
        <span class="chip active" data-filter="all">All</span>
        <span class="chip" data-filter="stable">Stable</span>
        <span class="chip" data-filter="beta">Beta</span>
        <span class="chip" data-filter="rc">RC</span>
        <span class="chip" data-filter="alpha">Alpha</span>
        <span class="chip" data-filter="patch">Patch</span>
        <span class="sep"></span>
        <input id="arc-q" type="text" placeholder="> filter versions..." />
      </div>

      <ul class="arc-list">
        {entries.map((e) => (
          <li class="arc-row" data-channel={e.data.channel} data-version={e.data.version}>
            <div class="arc-meta">
              <span class="arc-ver">v{e.data.version}</span>
              <span class={`arc-tag ${e.data.channel}`}>{channelLabel(e.data.channel)}</span>
              <span class="arc-date">{fmtDate(e.data.date)}</span>
            </div>
            <div class="arc-dl">
              {PLATFORMS.map((p) => (
                p.items.length === 1 ? (
                  <div class="arc-os-wrap" data-os={p.os}>
                    <a class="arc-btn" data-os={p.os}
                       href={downloadUrl(e.data.version, p.items[0].slug, p.items[0].ext)} download>
                      <span class="arc-btn-label">{p.label}</span>
                      <span class="arc-btn-arrow">↓</span>
                    </a>
                  </div>
                ) : (
                  <div class="arc-os-wrap has-menu" data-os={p.os}>
                    <button type="button" class="arc-btn arc-btn-toggle" data-os={p.os} aria-haspopup="true" aria-expanded="false">
                      <span class="arc-btn-label">{p.label}</span>
                      <span class="arc-btn-arrow">▾</span>
                    </button>
                    <div class="arc-menu" hidden>
                      {p.items.map((a) => (
                        <a class="arc-menu-item"
                           href={downloadUrl(e.data.version, a.slug, a.ext)} download>
                          <span class="ami-label">{a.label}</span>
                          <span class="ami-arch">{a.arch}</span>
                        </a>
                      ))}
                    </div>
                  </div>
                )
              ))}
            </div>
          </li>
        ))}
      </ul>
    </div>
  </main>
</BaseLayout>

<script>
  const chips = document.querySelectorAll<HTMLElement>('.filter-bar .chip');
  const rows = document.querySelectorAll<HTMLElement>('.arc-row');
  const q = document.getElementById('arc-q') as HTMLInputElement | null;
  let activeFilter = 'all';
  let query = '';

  function apply() {
    rows.forEach((r) => {
      const ch = r.dataset.channel ?? '';
      const v = r.dataset.version ?? '';
      const matchesFilter = activeFilter === 'all' || ch === activeFilter;
      const matchesQuery = !query || v.toLowerCase().includes(query);
      r.style.display = matchesFilter && matchesQuery ? '' : 'none';
    });
  }

  chips.forEach((c) => {
    c.addEventListener('click', () => {
      chips.forEach((x) => x.classList.remove('active'));
      c.classList.add('active');
      activeFilter = c.dataset.filter ?? 'all';
      apply();
    });
  });

  q?.addEventListener('input', () => {
    query = q.value.trim().toLowerCase();
    apply();
  });

  function closeAllMenus(except?: HTMLElement) {
    document.querySelectorAll<HTMLElement>('.arc-os-wrap.has-menu').forEach((wrap) => {
      if (wrap === except) return;
      const menu = wrap.querySelector<HTMLElement>('.arc-menu');
      const toggle = wrap.querySelector<HTMLButtonElement>('.arc-btn-toggle');
      menu?.setAttribute('hidden', '');
      wrap.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  }

  document.querySelectorAll<HTMLButtonElement>('.arc-btn-toggle').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const wrap = btn.closest<HTMLElement>('.arc-os-wrap.has-menu');
      const menu = wrap?.querySelector<HTMLElement>('.arc-menu');
      if (!wrap || !menu) return;
      const open = !menu.hasAttribute('hidden');
      closeAllMenus(open ? undefined : wrap);
      if (open) {
        menu.setAttribute('hidden', '');
        wrap.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
      } else {
        menu.removeAttribute('hidden');
        wrap.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  document.querySelectorAll<HTMLAnchorElement>('.arc-menu-item').forEach((a) => {
    a.addEventListener('click', () => closeAllMenus());
  });

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest('.arc-os-wrap.has-menu')) closeAllMenus();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeAllMenus();
  });
</script>

<style is:global>
  .page-head {
    max-width: 1360px; margin: 0 auto;
    padding: 64px 40px 40px;
    border-bottom: 1px solid var(--line);
  }
  .page-eyebrow {
    display: flex; align-items: center; gap: 14px;
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    color: var(--fg-muted); letter-spacing: 0.1em; text-transform: uppercase;
    margin-bottom: 24px;
  }
  .page-eyebrow .square { width: 8px; height: 8px; background: var(--accent); }
  .page-eyebrow .bar { flex: 1; height: 1px; background: var(--line-2); max-width: 100px; }
  .page-head h1 {
    font-size: clamp(48px, 8vw, 108px);
    line-height: 0.94; letter-spacing: -0.04em; font-weight: 500;
    max-width: 18ch;
  }
  .page-head h1 .accent { color: var(--accent); }
  .page-head .lede { margin-top: 28px; font-size: 17px; color: var(--fg-dim); max-width: 60ch; line-height: 1.55; }

  .arc-wrap { padding: 0 40px 80px; max-width: 1360px; margin: 0 auto; }

  .filter-bar {
    display: flex; gap: 10px; padding: 20px 0; border-bottom: 1px solid var(--line);
    font-family: 'JetBrains Mono', monospace; font-size: 11px; align-items: center;
    flex-wrap: wrap;
  }
  .filter-bar .chip {
    padding: 5px 10px; border: 1px solid var(--line-2); color: var(--fg-dim);
    cursor: pointer; letter-spacing: .05em; text-transform: uppercase;
    user-select: none;
  }
  .filter-bar .chip:hover { color: var(--fg); }
  .filter-bar .chip.active { background: var(--fg); color: var(--bg); border-color: var(--fg); }
  .filter-bar .sep { flex: 1; }
  .filter-bar input {
    height: 30px; padding: 0 12px; background: transparent;
    border: 1px solid var(--line-2); color: var(--fg); font: inherit;
    font-family: 'JetBrains Mono', monospace; font-size: 12px; width: 220px;
  }

  .arc-list { list-style: none; padding: 0; margin: 0; }
  .arc-row {
    display: grid; grid-template-columns: minmax(240px, 320px) minmax(0, 1fr);
    gap: 32px; align-items: center;
    padding: 20px 0; border-bottom: 1px solid var(--line);
  }
  .arc-row:last-child { border-bottom: 0; }

  .arc-meta { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .arc-ver {
    font-family: 'JetBrains Mono', monospace; font-size: 15px;
    color: var(--fg); font-weight: 600; letter-spacing: .02em;
  }
  .arc-tag {
    padding: 2px 6px; font-family: 'JetBrains Mono', monospace; font-size: 9px;
    font-weight: 500; background: var(--accent); color: var(--accent-ink);
    letter-spacing: .08em;
  }
  [data-theme="light"] .arc-tag { color: #fff; }
  .arc-tag.beta   { background: var(--blue); }
  .arc-tag.patch  { background: var(--green); }
  .arc-tag.rc     { background: var(--warn); }
  .arc-tag.alpha  { background: var(--pink); }
  .arc-tag.stable { background: var(--fg); color: var(--bg); }
  .arc-date {
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    color: var(--fg-muted); letter-spacing: .05em;
  }

  .arc-dl { display: flex; flex-wrap: wrap; gap: 8px; justify-content: flex-end; }
  .arc-os-wrap { position: relative; display: inline-flex; }
  .arc-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 7px 12px; border: 1px solid var(--line-2); color: var(--fg-dim);
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    text-decoration: none; letter-spacing: .03em; white-space: nowrap;
    transition: color .1s, border-color .1s, background .1s;
    background: transparent; cursor: pointer;
  }
  .arc-btn-toggle { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: .03em; }
  .arc-btn:hover {
    color: var(--fg); border-color: var(--fg); background: var(--bg-1);
  }
  .arc-os-wrap.has-menu.open .arc-btn { color: var(--fg); border-color: var(--fg); background: var(--bg-1); }
  .arc-btn-arrow { color: var(--fg-muted); font-size: 12px; }
  .arc-btn:hover .arc-btn-arrow,
  .arc-os-wrap.has-menu.open .arc-btn-arrow { color: var(--accent); }

  .arc-menu {
    position: absolute; right: 0; top: calc(100% + 4px);
    min-width: 200px;
    background: var(--bg); border: 1px solid var(--line-2);
    display: flex; flex-direction: column;
    z-index: 50;
  }
  .arc-menu[hidden] { display: none; }
  .arc-menu-item {
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    padding: 9px 12px;
    color: var(--fg); text-decoration: none;
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    border-bottom: 1px solid var(--line);
    transition: background .1s, color .1s;
  }
  .arc-menu-item:last-child { border-bottom: 0; }
  .arc-menu-item:hover { background: var(--bg-1); color: var(--accent); }
  .arc-menu-item .ami-arch {
    font-size: 10px; color: var(--fg-muted); letter-spacing: .05em;
  }
  .arc-menu-item:hover .ami-arch { color: var(--accent); }

  @media (max-width: 900px) {
    .arc-wrap { padding: 0 24px 40px; }
    .arc-row { grid-template-columns: 1fr; gap: 12px; padding: 18px 0; }
    .arc-dl { justify-content: flex-start; }
    .arc-menu { right: auto; left: 0; }
  }

  body { user-select: none; -webkit-user-select: none; }
  .filter-bar input { user-select: text; -webkit-user-select: text; }
</style>
