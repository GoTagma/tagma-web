---
/**
 * /showcase — placeholder
 *
 * Wired up so the V2 header's Showcase link doesn't 404. Replace
 * when real customer / example pipelines are ready to feature.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Showcase · Tagma" description="Pipelines built with Tagma — coming soon.">
  <section class="page-head">
    <div class="page-eyebrow">
      <span class="square"></span>
      <span>§ SHOWCASE · COMING SOON</span>
      <span class="bar"></span>
    </div>
    <h1>Pipelines in the wild.</h1>
    <p class="lede">
      Examples of real pipelines built with Tagma will live here. Want to be
      featured? Open an issue on GitHub.
    </p>
    <div style="display:flex; gap:12px; margin-top:16px;">
      <a class="ghost-btn" href="https://github.com/GoTagma/tagma-mono" target="_blank" rel="noopener">GitHub ↗</a>
      <a class="ghost-btn" href="/docs">Read the docs</a>
    </div>
  </section>
</BaseLayout>
